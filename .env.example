# ===========================================
# Sports Intelligence Platform - Environment
# ===========================================

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sports_intelligence
POSTGRES_USER=sip_user
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=changeme-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Data Sources
# Get free key at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
# BASKETBALL_API_KEY=

# Reporting
REPORTS_OUTPUT_DIR=/app/reports
REPORT_SCHEDULE_WEEKLY=0 8 * * 1
REPORT_SCHEDULE_MONTHLY=0 8 1 * *
