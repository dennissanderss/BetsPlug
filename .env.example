# ===========================================
# BetsPlug - Environment Variables
# ===========================================
# Copy to .env and fill in your values.
# Railway: set DATABASE_URL, REDIS_URL, FRONTEND_URL in the dashboard.
# Docker: use the individual POSTGRES_* and REDIS_* vars below.

# -------------------------------------------
# Database
# -------------------------------------------
# Option A: Full connection string (Railway, Supabase, Neon, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual vars (Docker Compose)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sports_intelligence
POSTGRES_USER=sip_user
POSTGRES_PASSWORD=changeme_in_production

# -------------------------------------------
# Redis
# -------------------------------------------
# Option A: Full connection string (Railway, Upstash, etc.)
# REDIS_URL=redis://default:password@host:6379

# Option B: Individual vars (Docker Compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -------------------------------------------
# Backend
# -------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=changeme-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
LOG_LEVEL=INFO

# -------------------------------------------
# CORS
# -------------------------------------------
# FRONTEND_URL is appended to allowed origins (used by Railway)
FRONTEND_URL=
CORS_ORIGINS=http://localhost:3000

# -------------------------------------------
# Frontend
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# -------------------------------------------
# Celery (task queue)
# -------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -------------------------------------------
# Data Sources
# -------------------------------------------
# Get a free key at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# -------------------------------------------
# Stripe Payments
# -------------------------------------------
# Get keys at: https://dashboard.stripe.com/apikeys
# Free to integrate -- you only pay per transaction (1.5% + 0.25 EUR)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# Create products + prices in Stripe Dashboard, then paste price IDs here:
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_LIFETIME=

# -------------------------------------------
# Reporting
# -------------------------------------------
REPORTS_OUTPUT_DIR=/app/reports
REPORT_SCHEDULE_WEEKLY=0 8 * * 1
REPORT_SCHEDULE_MONTHLY=0 8 1 * *
