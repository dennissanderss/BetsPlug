---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = "AI football predictions, daily Pick of the Day, and a public track record. Educational simulation only — 18+, no financial advice.",
  canonical,
} = Astro.props;

const canonicalUrl =
  canonical ?? `https://betsplug.com${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://betsplug.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BetsPlug · AI football predictions" />
    <meta property="og:site_name" content="BetsPlug" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://betsplug.com/og-image.jpg" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <slot />
  </body>
</html>
