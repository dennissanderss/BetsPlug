---
/**
 * BetsPlug Homepage — English root.
 * URL: / (no locale prefix; per i18n config defaultLocale=en)
 *
 * Spec: docs/specs/02-homepage.md
 *
 * Composition: 9 sections via dedicated homepage components.
 * Content sourced from src/content/pages/homepage/{locale}.json.
 *
 * The locale variant lives at src/pages/[locale]/index.astro and
 * delegates here through the same content-loader and components.
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { getContent, defaultLocale } from "@/lib/i18n";
import type { Locale } from "@/lib/i18n";
import type { HomepageContent } from "@/content/pages/homepage/types";

import Hero                    from "@/components/homepage/Hero.astro";
import HowItWorks              from "@/components/homepage/HowItWorks.astro";
import LivePredictionsPreview  from "@/components/homepage/LivePredictionsPreview.astro";
import MethodologyHighlight    from "@/components/homepage/MethodologyHighlight.astro";
import TrackRecordProof        from "@/components/homepage/TrackRecordProof.astro";
import ComparisonTable         from "@/components/homepage/ComparisonTable.astro";
import PricingTeaser           from "@/components/homepage/PricingTeaser.astro";
import HomepageFAQ             from "@/components/homepage/HomepageFAQ.astro";
import FinalCTA                from "@/components/homepage/FinalCTA.astro";
import SectionTransition       from "@/components/ui/SectionTransition.astro";

const locale: Locale = defaultLocale;
const content = await getContent<HomepageContent>("homepage", locale);

const SITE = "https://betsplug.com";

// Schema.org JSON-LD: Organization (full) + WebSite + FAQPage + BreadcrumbList.
// Verified valid against schema.org [2026-05-02]
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE}/#organization`,
  name: "BetsPlug",
  url: `${SITE}/`,
  logo: {
    "@type": "ImageObject",
    url: `${SITE}/logo.webp`,
    width: 512,
    height: 512,
  },
  description:
    "AI-driven football prediction platform with transparent track record. Statistical analysis only — not a bookmaker.",
  sameAs: [
    "https://t.me/betsplug_picks",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    email: "support@betsplug.com",
    contactType: "customer support",
    availableLanguage: ["en", "nl", "de", "fr", "es", "it", "sw"],
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE}/#website`,
  url: `${SITE}/`,
  name: "BetsPlug",
  inLanguage: locale,
  publisher: { "@id": `${SITE}/#organization` },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: content.faq.questions.map((q) => ({
    "@type": "Question",
    name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${SITE}/`,
    },
  ],
};
---

<MarketingLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  canonicalPath="/"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  {/* Section ritme: Hero=dark → HowItWorks=light → Live=dark → Methodology=dark
      → TrackRecord=light → Comparison=light → Pricing=dark → FAQ=light → FinalCTA=dark.
      SectionTransition strips bridge dark↔light boundaries so the page reads as
      one canvas. Same-surface boundaries (e.g. dark→dark) get no strip. */}

  <Hero                   locale={locale} content={content.hero} />
  <SectionTransition from="dark" to="light" />

  <HowItWorks             locale={locale} content={content.howItWorks} />
  <SectionTransition from="light" to="dark" />

  <LivePredictionsPreview locale={locale} content={content.livePredictions} />
  <MethodologyHighlight   locale={locale} content={content.methodology} />
  <SectionTransition from="dark" to="light" />

  <TrackRecordProof       locale={locale} content={content.trackRecord} />
  <ComparisonTable        locale={locale} content={content.comparison} />
  <SectionTransition from="light" to="dark" />

  <PricingTeaser          locale={locale} content={content.pricing} />
  <SectionTransition from="dark" to="light" />

  <HomepageFAQ            locale={locale} content={content.faq} />
  <SectionTransition from="light" to="dark" />

  <FinalCTA               content={content.finalCta} />
</MarketingLayout>
