---
/**
 * /how-it-works — English root.
 * Locale variants live under src/pages/[locale]/[slug].astro and
 * delegate to the same HowItWorksPage component via the same loader.
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import HowItWorksPage from "@/components/how-it-works/HowItWorksPage.astro";
import { loadHowItWorksContent } from "@/lib/how-it-works-page";

const locale = "en" as const;
const content = await loadHowItWorksContent(locale);

const SITE = "https://betsplug.com";

// Schema.org HowTo + Breadcrumb. The HowTo type is the natural fit for
// a six-step pipeline page and unlocks rich-result eligibility.
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: content.meta.title,
  description: content.meta.description,
  inLanguage: locale,
  step: content.steps.map((s, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: s.title,
    text: s.body,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "How it works", item: `${SITE}/how-it-works` },
  ],
};
---

<MarketingLayout
  title={content.meta.title}
  description={content.meta.description}
  canonicalPath="/how-it-works"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <HowItWorksPage locale={locale} content={content} />
</MarketingLayout>
