---
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import Footer from "../../components/Footer.astro";
import PageHeader from "../../components/PageHeader.astro";
import Prose from "../../components/Prose.astro";
import {
  sanity,
  allLearnPillarsQuery,
  learnPillarBySlugQuery,
  localised,
  renderPortableText,
  type LearnPillar,
  type LearnPillarSummary,
} from "../../lib/sanity";

// Pre-render every pillar at build time. Sanity's read endpoint is
// fast and the dataset is small, so going static is the right call —
// instant page loads, perfect Lighthouse, no runtime cost.
export async function getStaticPaths() {
  let pillars: LearnPillarSummary[] = [];
  try {
    pillars = await sanity.fetch<LearnPillarSummary[]>(allLearnPillarsQuery);
  } catch {
    // Build with no pillars rather than crashing the whole site.
  }

  return pillars.map((p) => ({
    params: { slug: p.slug.current },
  }));
}

const { slug } = Astro.params;

let pillar: LearnPillar | null = null;
try {
  pillar = await sanity.fetch<LearnPillar | null>(learnPillarBySlugQuery, {
    slug,
  });
} catch {
  pillar = null;
}

if (!pillar) {
  // Fallthrough — return a 404. Astro handles this with the
  // platform's default 404 page on Vercel/Netlify.
  return Astro.redirect("/learn", 302);
}

const title = localised(pillar.title);
const tagline = localised(pillar.tagline);
const metaTitle =
  localised(pillar.metaTitle) ||
  `${title} — Learn at BetsPlug`;
const metaDescription =
  localised(pillar.metaDescription) || tagline;

// Sanity sections store body as locale-keyed portable-text:
// { en: [...blocks], nl: [...blocks] }. Pull EN.
function localisedPortableText(value: any, locale = "en"): unknown {
  if (!value) return null;
  if (Array.isArray(value)) return value;
  return value[locale] ?? value.en ?? null;
}
---

<Layout title={metaTitle} description={metaDescription}>
  <SiteNav />

  <main>
    <PageHeader
      kicker="Learn"
      title={title}
      subtitle={tagline}
    />

    {pillar.intro && (
      <Prose>
        <Fragment
          set:html={renderPortableText(localisedPortableText(pillar.intro))}
        />
      </Prose>
    )}

    {pillar.sections && pillar.sections.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 pb-8 sm:px-6 lg:px-8">
        {pillar.sections.map((section) => (
          <Prose>
            {section.heading && (
              <h2>{localised(section.heading)}</h2>
            )}
            <Fragment
              set:html={renderPortableText(
                localisedPortableText(section.body),
              )}
            />
          </Prose>
        ))}
      </section>
    )}

    {pillar.faqs && pillar.faqs.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 pb-12 sm:px-6 lg:px-8">
        <h2 class="mb-4 text-xl font-bold text-white">
          Frequently asked
        </h2>
        <div class="space-y-3">
          {pillar.faqs.map((faq) => (
            <details class="card-neon p-4">
              <summary class="cursor-pointer text-sm font-semibold text-white">
                {localised(faq.question)}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
                {localised(faq.answer)}
              </p>
            </details>
          ))}
        </div>
      </section>
    )}

    {pillar.related && pillar.related.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 pb-12 sm:px-6 lg:px-8">
        <h2 class="mb-4 text-xl font-bold text-white">Keep reading</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {pillar.related.map((rel) => (
            <a
              href={`/learn/${rel.slug.current}`}
              class="card-neon block p-4 transition-transform hover:-translate-y-0.5"
            >
              <p class="text-sm font-semibold text-white">
                {localised(rel.title)}
              </p>
              <p class="mt-1 text-xs text-[var(--color-text-muted)]">
                {localised(rel.tagline)}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    <Footer />
  </main>
</Layout>
