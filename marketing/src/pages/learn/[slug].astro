---
/**
 * Learn article — English root.
 * URL: /learn/{slug}
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";

import ArticleHero            from "@/components/learn/article/ArticleHero.astro";
import ArticleTableOfContents from "@/components/learn/article/ArticleTableOfContents.astro";
import ArticleBody            from "@/components/learn/article/ArticleBody.astro";
import KeyTakeaways           from "@/components/learn/article/KeyTakeaways.astro";
import ArticleFAQ             from "@/components/learn/article/ArticleFAQ.astro";
import RelatedArticles        from "@/components/learn/article/RelatedArticles.astro";
import ApplyThisCTA           from "@/components/learn/article/ApplyThisCTA.astro";

import { loadArticle, listArticleSlugs, type ArticleSlug } from "@/lib/article-page";
import { loadLearnHubContent } from "@/lib/learn-page";

export function getStaticPaths() {
  const slugs = [
    "expected-goals-explained",
    "elo-rating-explained",
    "poisson-goal-models",
    "what-is-value-betting",
    "kelly-criterion",
    "bankroll-management",
    "ai-vs-tipsters",
  ];
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug: paramSlug } = Astro.params;
if (!paramSlug || !listArticleSlugs().includes(paramSlug as ArticleSlug)) {
  return Astro.redirect("/learn", 302);
}
const slug = paramSlug as ArticleSlug;
const locale = "en" as const;
const article = await loadArticle(slug, locale);
const hub = await loadLearnHubContent(locale);

const allHubArticles = hub.grid.categories.flatMap((c) => c.articles);
const relatedArticleCards = article.relatedArticles.slugs
  .map((s) => allHubArticles.find((a) => a.slug === s))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));

const SITE = "https://betsplug.com";
const canonicalPath = `/learn/${slug}`;

const techArticleSchema = {
  "@context": "https://schema.org", "@type": "TechArticle",
  headline: article.header.h1, description: article.meta.description,
  author: { "@type": "Organization", name: "BetsPlug" },
  publisher: { "@type": "Organization", name: "BetsPlug", logo: { "@type": "ImageObject", url: `${SITE}/logo.webp` } },
  datePublished: article.header.publishedAt, dateModified: article.header.updatedAt,
  articleSection: article.header.category, inLanguage: locale,
  url: `${SITE}${canonicalPath}`,
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",  item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Learn", item: `${SITE}/learn` },
    { "@type": "ListItem", position: 3, name: article.header.h1, item: `${SITE}${canonicalPath}` },
  ],
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: article.faq.questions.map((q) => ({
    "@type": "Question", name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};
---

<MarketingLayout
  title={article.meta.title}
  description={article.meta.description}
  ogImage={article.meta.ogImage}
  canonicalPath={canonicalPath}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(techArticleSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ArticleHero
    locale={locale}
    header={article.header}
    intro={article.intro}
    breadcrumbLearn={article.breadcrumbLearn}
    difficultyLabels={hub.grid.difficultyLabels}
  />

  <Section surface="light" spacing="lg">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">
        <div class="lg:col-span-3">
          <ArticleTableOfContents label={article.tocLabel} sections={article.sections} />
        </div>
        <article class="lg:col-span-9 max-w-3xl">
          <ArticleBody    sections={article.sections} />
          <KeyTakeaways   content={article.keyTakeaways} />
          <ArticleFAQ     content={article.faq} />
        </article>
      </div>
    </Container>
  </Section>

  {relatedArticleCards.length > 0 && (
    <RelatedArticles
      locale={locale}
      h2={article.relatedArticles.h2}
      articles={relatedArticleCards}
      readMoreLabel={hub.grid.readMore}
      difficultyLabels={hub.grid.difficultyLabels}
    />
  )}

  <ApplyThisCTA locale={locale} content={article.applyThis} />
</MarketingLayout>
