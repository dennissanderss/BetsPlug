---
/**
 * Learn hub — English root.
 * URL: /learn
 *
 * Spec: docs/specs/11-learn-hub.md
 *
 * Sections:
 *   1. LearnHero
 *   2. ArticleGrid (7 articles in 3 categories)
 *   3. WhyTheseTopics
 *   4. LearnFinalCTA
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import LearnHero       from "@/components/learn/LearnHero.astro";
import ArticleGrid     from "@/components/learn/ArticleGrid.astro";
import WhyTheseTopics  from "@/components/learn/WhyTheseTopics.astro";
import LearnFinalCTA   from "@/components/learn/LearnFinalCTA.astro";
import { loadLearnHubContent } from "@/lib/learn-page";
import { getLocalizedSlug } from "@/lib/i18n";

const locale = "en" as const;
const content = await loadLearnHubContent(locale);

const SITE = "https://betsplug.com";
const canonicalPath = "/learn";

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",  item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Learn", item: `${SITE}${canonicalPath}` },
  ],
};

// Flatten all articles for the ItemList schema.
const allArticles = content.grid.categories.flatMap((c) => c.articles);
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  url: `${SITE}${canonicalPath}`,
  inLanguage: locale,
  name: content.meta.title,
  description: content.meta.description,
  hasPart: allArticles.map((a) => ({
    "@type": "TechArticle",
    headline: a.title,
    description: a.excerpt,
    url: `${SITE}/learn/${getLocalizedSlug(a.slug, locale)}`,
  })),
};
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: allArticles.map((a, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "TechArticle",
      headline: a.title,
      description: a.excerpt,
      url: `${SITE}/learn/${getLocalizedSlug(a.slug, locale)}`,
    },
  })),
};
---

<MarketingLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  canonicalPath={canonicalPath}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <LearnHero       content={content.hero} />
  <ArticleGrid     locale={locale} content={content.grid} />
  <WhyTheseTopics  content={content.whyTopics} />
  <LearnFinalCTA   locale={locale} content={content.finalCta} />
</MarketingLayout>
