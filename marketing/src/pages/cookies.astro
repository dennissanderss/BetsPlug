---
import LegalLayout from "@/layouts/LegalLayout.astro";
import { loadLegalContent } from "@/lib/legal-page";

const locale = "en" as const;
const content = loadLegalContent("cookies", locale);

const SITE = "https://betsplug.com";
const canonicalPath = "/cookies";

const webPageSchema = {
  "@context": "https://schema.org", "@type": "WebPage",
  name: content.meta.title, description: content.meta.description,
  inLanguage: locale, url: `${SITE}${canonicalPath}`,
  dateModified: content._meta.lastUpdated, datePublished: content._meta.effectiveDate,
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Cookies", item: `${SITE}${canonicalPath}` },
  ],
};
---

<LegalLayout content={content} canonicalPath={canonicalPath}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
</LegalLayout>
