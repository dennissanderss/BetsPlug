---
/**
 * Legacy /bet-types/{slug} URLs from the old NOCTURNE build are
 * consolidated into the new /bet-types pillar page. Each legacy slug
 * 301-redirects to the matching anchor on the pillar.
 *
 * Per spec docs/specs/01-site-architecture.md "URLs die samenvoegen
 * tot pillar".
 */
const slugToAnchor: Record<string, string> = {
  "both-teams-to-score":  "btts",
  "double-chance":        "double-chance",
  "draw-no-bet":          "draw-no-bet",
  "over-2-5-goals":       "over-under",
  "asian-handicap":       "asian-handicap",
  "correct-score":        "correct-score",
  "ht-ft":                "ht-ft",
  "match-result":         "match-result",
};

export function getStaticPaths() {
  return Object.keys({
    "both-teams-to-score":  "btts",
    "double-chance":        "double-chance",
    "draw-no-bet":          "draw-no-bet",
    "over-2-5-goals":       "over-under",
    "asian-handicap":       "asian-handicap",
    "correct-score":        "correct-score",
    "ht-ft":                "ht-ft",
    "match-result":         "match-result",
  }).map((slug) => ({ params: { slug } }));
}

const anchor = slugToAnchor[String(Astro.params.slug ?? "")];
return Astro.redirect(anchor ? `/bet-types#${anchor}` : "/bet-types", 301);
---
