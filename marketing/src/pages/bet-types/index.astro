---
/**
 * Bet Types pillar page — English root.
 * URL: /bet-types
 *
 * Spec: docs/specs/13-bet-types.md
 *
 * 8 unique bet-type sections + coverage table + FAQ + final CTA.
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";

import BetTypesHero      from "@/components/bet-types/BetTypesHero.astro";
import BetTypesTOC       from "@/components/bet-types/BetTypesTOC.astro";
import BetTypeSectionC   from "@/components/bet-types/BetTypeSection.astro";
import CoverageTable     from "@/components/bet-types/CoverageTable.astro";
import BetTypesFAQ       from "@/components/bet-types/BetTypesFAQ.astro";
import BetTypesFinalCTA  from "@/components/bet-types/BetTypesFinalCTA.astro";

import { loadBetTypesContent } from "@/lib/bet-types-page";
import { stripAccent } from "@/lib/parseAccent";

const locale = "en" as const;
const content = await loadBetTypesContent(locale);

const SITE = "https://betsplug.com";
const canonicalPath = "/bet-types";

const techArticleSchema = {
  "@context": "https://schema.org", "@type": "TechArticle",
  headline: stripAccent(content.hero.h1), description: content.meta.description,
  author: { "@type": "Organization", name: "BetsPlug" },
  publisher: { "@type": "Organization", name: "BetsPlug", logo: { "@type": "ImageObject", url: `${SITE}/logo.webp` } },
  datePublished: "2026-04-15", dateModified: content._meta.lastUpdated,
  articleSection: "Betting Markets",
  inLanguage: locale,
  url: `${SITE}${canonicalPath}`,
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",      item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Bet Types", item: `${SITE}${canonicalPath}` },
  ],
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: content.faq.questions.map((q) => ({
    "@type": "Question", name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};
---

<MarketingLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  canonicalPath={canonicalPath}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(techArticleSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <BetTypesHero content={content.hero} />

  <Section surface="light" spacing="lg">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">
        <div class="lg:col-span-3">
          <BetTypesTOC toc={content.toc} />
        </div>
        <article class="lg:col-span-9">
          {content.betTypes.map((section) => (
            <BetTypeSectionC section={section} labels={content.sectionLabels} />
          ))}

          <CoverageTable locale={locale} content={content.coverage} />

          <BetTypesFAQ content={content.faq} />
        </article>
      </div>
    </Container>
  </Section>

  <BetTypesFinalCTA locale={locale} content={content.finalCta} />
</MarketingLayout>
