---
/**
 * Track Record — English root.
 * URL: /track-record
 *
 * Trust-building page (no live data). Sections:
 *   1. TrackRecordHero
 *   2. WhyTransparencyMatters
 *   3. TransparencyPillars
 *   4. WhatYouCanVerify (with stylized AppMockup)
 *   5. MethodologyConnection
 *   6. TrackRecordFAQ
 *   7. TrackRecordFinalCTA
 */
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { getContent } from "@/lib/i18n";
import { stripAccent } from "@/lib/parseAccent";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

import TrackRecordHero        from "@/components/track-record/TrackRecordHero.astro";
import WhyTransparencyMatters from "@/components/track-record/WhyTransparencyMatters.astro";
import TransparencyPillars    from "@/components/track-record/TransparencyPillars.astro";
import WhatYouCanVerify       from "@/components/track-record/WhatYouCanVerify.astro";
import MethodologyConnection  from "@/components/track-record/MethodologyConnection.astro";
import TrackRecordFAQ         from "@/components/track-record/TrackRecordFAQ.astro";
import TrackRecordFinalCTA    from "@/components/track-record/TrackRecordFinalCTA.astro";

const locale = "en" as const;
const content = await getContent<TrackRecordContent>("track-record", locale);

const SITE = "https://betsplug.com";
const canonicalPath = "/track-record";

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: stripAccent(content.hero.h1),
  description: content.meta.description,
  url: `${SITE}${canonicalPath}`,
  inLanguage: locale,
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",         item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Track Record", item: `${SITE}${canonicalPath}` },
  ],
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: content.faq.questions.map((q) => ({
    "@type": "Question",
    name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};
---

<MarketingLayout
  title={content.meta.title}
  description={content.meta.description}
  ogImage={content.meta.ogImage}
  canonicalPath={canonicalPath}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <TrackRecordHero        locale={locale} content={content.hero} />
  <WhyTransparencyMatters content={content.whyTransparency} />
  <TransparencyPillars    content={content.pillars} />
  <WhatYouCanVerify       locale={locale} content={content.whatYouCanVerify} />
  <MethodologyConnection  locale={locale} content={content.methodologyConnection} />
  <TrackRecordFAQ         content={content.faq} />
  <TrackRecordFinalCTA    locale={locale} content={content.finalCta} />
</MarketingLayout>
