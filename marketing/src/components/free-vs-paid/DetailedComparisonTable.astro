---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { FreeVsPaidContent } from "@/content/pages/free-vs-paid/types";

interface Props {
  locale: Locale;
  content: FreeVsPaidContent["comparison"];
}
const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="dark" spacing="lg" ariaLabelledby="comparison-h2">
  <Container size="lg">
    <header class="text-center max-w-2xl mx-auto">
      <h2 id="comparison-h2" class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure">
        {content.h2}
      </h2>
    </header>

    <div class="mt-10 overflow-hidden rounded-2xl border border-deep-navy-600 bg-charcoal-700">
      <table class="w-full text-left">
        <thead class="bg-deep-navy-800">
          <tr>
            <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-white-muted">{content.headers.feature}</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-white-muted text-center">{content.headers.free}</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-pitch-green-400 text-center">{content.headers.silver}</th>
            <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-pitch-green-400 text-center">{content.headers.gold}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-deep-navy-600">
          {content.rows.map((row) => (
            <tr>
              <th scope="row" class="px-6 py-4 text-sm font-medium text-white-soft">{row.feature}</th>
              <td class="px-6 py-4 text-sm text-white-muted text-center">{row.free}</td>
              <td class="px-6 py-4 text-sm font-medium text-white-pure text-center">{row.silver}</td>
              <td class="px-6 py-4 text-sm font-medium text-white-pure text-center">{row.gold}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-8 text-center">
      <a href={ctaHref} class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-400 hover:text-pitch-green-300 transition-colors">
        {content.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </Container>
</Section>
