---
import Container from "@/components/ui/Container.astro";
import PitchLinePattern from "@/components/ui/PitchLinePattern.astro";
import { parseAccent } from "@/lib/parseAccent";
import type { FreeVsPaidContent } from "@/content/pages/free-vs-paid/types";

interface Props { content: FreeVsPaidContent["hero"] }
const { content } = Astro.props;
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[30vh] py-14 md:py-16" aria-labelledby="fvp-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-dark);"></div>
  <PitchLinePattern variant="subtle" position="full" />
  <div aria-hidden="true" class="pointer-events-none absolute -top-20 right-[-10%] h-[420px] w-[420px] rounded-full opacity-30 blur-[100px]" style="background: radial-gradient(circle, rgba(0,210,106,0.40) 0%, rgba(0,210,106,0) 70%);"></div>

  <Container size="md" class="relative text-center">
    <h1 id="fvp-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] tracking-tight text-white-pure" set:html={parseAccent(content.h1)}></h1>
    <p class="mt-5 text-lg leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>
  </Container>
</section>
