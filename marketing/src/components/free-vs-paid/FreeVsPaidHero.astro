---
import Container from "@/components/ui/Container.astro";
import GlowOrb from "@/components/ui/GlowOrb.astro";
import StadiumLightArc from "@/components/ui/StadiumLightArc.astro";
import { parseAccent } from "@/lib/parseAccent";
import type { FreeVsPaidContent } from "@/content/pages/free-vs-paid/types";

interface Props { content: FreeVsPaidContent["hero"] }
const { content } = Astro.props;
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[30vh] py-14 md:py-16 isolate" aria-labelledby="fvp-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-atmospheric);"></div>
  <StadiumLightArc position="top-center" intensity="low" />
  <GlowOrb size="lg" color="pitch-green" position="top-right" intensity="low" blur={100} />

  <Container size="md" class="relative z-10 text-center">
    <h1 id="fvp-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] tracking-tight text-white-pure" set:html={parseAccent(content.h1)}></h1>
    <p class="mt-5 text-lg leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>
  </Container>
</section>
