---
/**
 * Homepage HowItWorks — Section 2.
 * See docs/specs/02-homepage.md → "SECTIE 2: HOW IT WORKS".
 *
 * Three numbered steps on a light surface. Lucide-style line icons,
 * stroke-width 2. Mobile: stacked. Desktop: 3-column grid.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { HomepageContent } from "@/content/pages/homepage/types";

interface Props {
  locale: Locale;
  content: HomepageContent["howItWorks"];
}

const { locale, content } = Astro.props;

const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="light" spacing="lg" ariaLabelledby="how-it-works-h2">
  <Container size="lg">
    <header class="text-center max-w-2xl mx-auto">
      <h2
        id="how-it-works-h2"
        class="text-3xl sm:text-4xl lg:text-[44px] font-bold leading-tight tracking-tight text-charcoal-900"
      >
        {content.h2}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-charcoal-700">
        {content.subhead}
      </p>
    </header>

    <ol class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10" role="list">
      {content.steps.map((step) => (
        <li class="relative">
          <article class="h-full">
            <!-- Step number + icon -->
            <div class="flex items-center gap-4">
              <span
                class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl
                       bg-pitch-green-500/10 text-pitch-green-600"
                aria-hidden="true"
              >
                {step.icon === "database" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="8" ry="3" />
                    <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5" />
                    <path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" />
                  </svg>
                )}
                {step.icon === "cpu" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="4" width="16" height="16" rx="2" />
                    <rect x="9" y="9" width="6" height="6" />
                    <line x1="9" y1="1" x2="9" y2="4" />
                    <line x1="15" y1="1" x2="15" y2="4" />
                    <line x1="9" y1="20" x2="9" y2="23" />
                    <line x1="15" y1="20" x2="15" y2="23" />
                    <line x1="20" y1="9" x2="23" y2="9" />
                    <line x1="20" y1="14" x2="23" y2="14" />
                    <line x1="1" y1="9" x2="4" y2="9" />
                    <line x1="1" y1="14" x2="4" y2="14" />
                  </svg>
                )}
                {step.icon === "lock" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                  </svg>
                )}
              </span>
              <span
                class="font-mono text-3xl font-bold tracking-tight text-pitch-green-600"
                aria-hidden="true"
              >
                {step.number}
              </span>
            </div>

            <h3 class="mt-5 text-xl font-bold text-charcoal-900">
              {step.h3}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-charcoal-700">
              {step.body}
            </p>
            <p class="mt-4 text-xs font-medium uppercase tracking-wider text-charcoal-500">
              {step.microDetail}
            </p>
          </article>
        </li>
      ))}
    </ol>

    <div class="mt-12 text-center">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-600
               hover:text-pitch-green-500 transition-colors duration-150
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400
               focus-visible:ring-offset-2 focus-visible:ring-offset-stadium-white-50 rounded-md"
      >
        {content.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
      </a>
    </div>
  </Container>
</Section>
