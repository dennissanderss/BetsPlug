---
/**
 * Homepage ComparisonTable — Section 6.
 * See docs/specs/02-homepage.md → "SECTIE 6: COMPARISON TABLE".
 *
 * 8-row comparison: Traditional Tipsters vs BetsPlug AI.
 * X (red) on the tipster column, ✓ (green) on the BetsPlug column —
 * applied to qualitative differences. Mobile: stacked card-pairs.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { HomepageContent } from "@/content/pages/homepage/types";

interface Props {
  locale: Locale;
  content: HomepageContent["comparison"];
}

const { locale, content } = Astro.props;

const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="light-clean" spacing="lg" ariaLabelledby="comparison-h2">
  <Container size="lg">
    <header class="text-center max-w-3xl mx-auto">
      <h2
        id="comparison-h2"
        class="text-3xl sm:text-4xl lg:text-[44px] font-bold leading-tight tracking-tight text-charcoal-900"
      >
        {content.h2}
      </h2>
    </header>

    <!-- Desktop table -->
    <div class="mt-12 hidden md:block">
      <div class="overflow-hidden rounded-2xl border border-stadium-white-200 bg-white shadow-[var(--shadow-sm)]">
        <table class="w-full text-left">
          <thead class="bg-stadium-white-100">
            <tr>
              <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-charcoal-500">
                {content.headers.criterion}
              </th>
              <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-charcoal-500">
                {content.headers.tipster}
              </th>
              <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-pitch-green-600">
                {content.headers.betsplug}
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stadium-white-200">
            {content.rows.map((row) => (
              <tr>
                <th scope="row" class="px-6 py-4 text-sm font-medium text-charcoal-900">
                  {row.criterion}
                </th>
                <td class="px-6 py-4 text-sm text-charcoal-700">
                  <span class="inline-flex items-center gap-2">
                    <svg class="h-4 w-4 text-danger shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    {row.tipster}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm font-medium text-charcoal-900">
                  <span class="inline-flex items-center gap-2">
                    <svg class="h-4 w-4 text-pitch-green-600 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {row.betsplug}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile: paired card list -->
    <div class="mt-12 md:hidden space-y-4">
      {content.rows.map((row) => (
        <div class="rounded-xl border border-stadium-white-200 bg-white p-4 shadow-[var(--shadow-sm)]">
          <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500">
            {row.criterion}
          </p>
          <div class="mt-3 space-y-2">
            <div class="flex items-start gap-2">
              <svg class="h-4 w-4 text-danger shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm text-charcoal-700">
                <span class="text-xs text-charcoal-500">{content.headers.tipster}:</span>{" "}
                {row.tipster}
              </p>
            </div>
            <div class="flex items-start gap-2">
              <svg class="h-4 w-4 text-pitch-green-600 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm font-medium text-charcoal-900">
                <span class="text-xs text-charcoal-500 font-normal">{content.headers.betsplug}:</span>{" "}
                {row.betsplug}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footnote -->
    <p class="mt-10 text-base lg:text-lg leading-relaxed text-charcoal-700 max-w-3xl mx-auto text-center italic">
      {content.footnote}
    </p>

    <div class="mt-8 text-center">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-600
               hover:text-pitch-green-500 transition-colors duration-150
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400
               focus-visible:ring-offset-2 focus-visible:ring-offset-stadium-white-50 rounded-md"
      >
        {content.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
      </a>
    </div>
  </Container>
</Section>
