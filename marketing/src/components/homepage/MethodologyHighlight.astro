---
/**
 * Homepage MethodologyHighlight — Section 4.
 * See docs/specs/02-homepage.md → "SECTIE 4: METHODOLOGY HIGHLIGHT".
 *
 * 50/50 split: copy left, vector engine diagram + 4 stat callouts
 * right. Dark surface with pitch-green accents.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { HomepageContent } from "@/content/pages/homepage/types";

interface Props {
  locale: Locale;
  content: HomepageContent["methodology"];
}

const { locale, content } = Astro.props;

const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="dark" spacing="lg" ariaLabelledby="methodology-h2">
  <Container size="xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Copy (left) -->
      <div>
        <h2
          id="methodology-h2"
          class="text-3xl sm:text-4xl lg:text-[44px] font-bold leading-tight tracking-tight text-white-pure"
          set:html={parseAccent(content.h2)}
        ></h2>

        <div class="mt-6 space-y-5 text-base lg:text-[17px] leading-relaxed text-white-soft">
          {content.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>

        <div class="mt-8">
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-400
                   hover:text-pitch-green-300 transition-colors duration-150
                   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400
                   focus-visible:ring-offset-2 focus-visible:ring-offset-deep-navy-900 rounded-md"
          >
            {content.cta.label}
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        </div>
      </div>

      <!-- Diagram + stats (right) -->
      <div class="space-y-8">
        <!-- Engine diagram -->
        <div
          class="rounded-2xl border border-deep-navy-600 bg-deep-navy-800/60 p-6 lg:p-8"
          aria-label="Engine flow diagram"
        >
          <!-- Input layer -->
          <div class="text-center">
            <p class="text-xs font-semibold uppercase tracking-wider text-pitch-green-400">
              {content.diagram.input}
            </p>
            <div class="mt-3 flex flex-wrap justify-center gap-2">
              {content.diagram.inputItems.map((item) => (
                <span class="inline-flex items-center rounded-md border border-deep-navy-600 bg-deep-navy-900 px-3 py-1.5 text-xs font-medium text-white-soft">
                  {item}
                </span>
              ))}
            </div>
          </div>

          <!-- Connector arrows down -->
          <div class="my-4 flex justify-center" aria-hidden="true">
            <svg class="h-6 w-6 text-pitch-green-500/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <polyline points="19 12 12 19 5 12" />
            </svg>
          </div>

          <!-- Models layer (3 parallel) -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {content.diagram.models.map((model) => (
              <div class="rounded-lg border border-pitch-green-500/30 bg-pitch-green-500/5 p-4 text-center">
                <p class="text-sm font-semibold text-pitch-green-400">{model}</p>
              </div>
            ))}
          </div>

          <!-- Connector arrows down -->
          <div class="my-4 flex justify-center" aria-hidden="true">
            <svg class="h-6 w-6 text-pitch-green-500/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <polyline points="19 12 12 19 5 12" />
            </svg>
          </div>

          <!-- Output -->
          <div class="rounded-lg bg-pitch-green-500 p-4 text-center text-deep-navy-950">
            <div class="inline-flex items-center gap-2 font-bold text-sm">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z" clip-rule="evenodd" />
              </svg>
              {content.diagram.output}
            </div>
          </div>
        </div>

        <!-- Stat callouts (2x2 grid) -->
        <dl class="grid grid-cols-2 gap-4">
          {content.stats.map((stat) => (
            <div class="rounded-xl border border-deep-navy-600 bg-charcoal-700 p-5 text-center">
              <dt class="font-mono text-3xl lg:text-4xl font-bold text-pitch-green-400">
                {stat.value}
              </dt>
              <dd class="mt-1 text-xs font-medium uppercase tracking-wider text-white-muted">
                {stat.label}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </Container>
</Section>
