---
/**
 * Homepage Hero — Section 1.
 * See docs/specs/02-homepage.md → "SECTIE 1: HERO".
 *
 * Asymmetric hero (60% copy / 40% visual on desktop). Dark surface
 * with ambient pitch-green glow. The visual is a vector "live
 * prediction" card mockup — no stock photos, no video.
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { HomepageContent } from "@/content/pages/homepage/types";

// Trust-strip claims map 1:1 onto these icons (positional —
// content JSON keeps the strings translatable, the icon list lives
// here so we don't have to migrate every locale's content schema).
const TRUST_ICONS: IconName[] = ["lock", "eye", "shield-check"];

interface Props {
  locale: Locale;
  content: HomepageContent["hero"];
}

const { locale, content } = Astro.props;

const secondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);

const confidenceWidth = `${Math.max(0, Math.min(100, content.visual.confidence))}%`;
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft
         min-h-[80vh] md:min-h-[640px] lg:min-h-[100vh]
         flex items-center"
  aria-labelledby="hero-h1"
>
  <!-- Background — radial gradient + pitch-line pattern -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background: var(--gradient-hero-dark);"
  ></div>

  <!-- Pitch-line pattern overlay (very subtle, 2% opacity) -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 h-full w-full opacity-[0.025] pointer-events-none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="pitch-grid" width="80" height="80" patternUnits="userSpaceOnUse">
        <path d="M 80 0 L 0 0 0 80" fill="none" stroke="white" stroke-width="1" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#pitch-grid)" />
  </svg>

  <!-- Ambient pitch-green glow (top right) -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 right-[-12%] h-[560px] w-[560px] rounded-full opacity-50 blur-[100px]"
    style="background: radial-gradient(circle, rgba(0,210,106,0.40) 0%, rgba(0,210,106,0) 70%);"
  ></div>

  <Container size="xl" class="relative py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Content (60%) -->
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-pitch-green-400">
          {content.kicker}
        </p>

        <h1
          id="hero-h1"
          class="mt-4 text-4xl sm:text-5xl lg:text-6xl xl:text-[64px]
                 font-bold leading-[1.05] tracking-tight text-white-pure"
          set:html={parseAccent(content.h1)}
        ></h1>

        <p class="mt-6 max-w-2xl text-lg sm:text-xl leading-relaxed text-white-soft">
          {content.subheadline}
        </p>

        <!-- Trust strip -->
        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {content.trustStrip.map((item, i) => (
            <li>
              <USPItem
                icon={TRUST_ICONS[i] ?? "check"}
                text={item}
                size="sm"
                surface="dark"
              />
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <Button
            href={content.ctaPrimary.href}
            variant="primary"
            size="lg"
            surface="dark"
            external
          >
            {content.ctaPrimary.label}
            <svg
              slot="trailing"
              class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"
              />
            </svg>
          </Button>

          <Button
            href={secondaryHref}
            variant="secondary"
            size="lg"
            surface="dark"
          >
            {content.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <!-- Visual (40%) -->
      <div class="lg:col-span-5 lg:flex lg:justify-end">
        <div class="relative w-full max-w-md mx-auto lg:max-w-none">
          <!-- Floating motion wrapper -->
          <div class="hero-card-float">
            <!-- Prediction card mockup -->
            <div
              class="relative rounded-2xl border border-deep-navy-600
                     bg-deep-navy-800/90 backdrop-blur-sm p-6 shadow-[var(--shadow-xl)]"
            >
              <!-- Top: league + lock -->
              <div class="flex items-center justify-between text-xs">
                <span class="inline-flex items-center gap-2 rounded-full bg-deep-navy-700 px-3 py-1 font-semibold text-white-soft">
                  <span class="h-1.5 w-1.5 rounded-full bg-pitch-green-500"></span>
                  {content.visual.league}
                </span>
                <span class="inline-flex items-center gap-1 text-white-muted">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z" clip-rule="evenodd" />
                  </svg>
                  {content.visual.lockLabel}
                </span>
              </div>

              <!-- Teams -->
              <div class="mt-6 space-y-3">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 shrink-0 rounded-full bg-charcoal-700 flex items-center justify-center text-white-soft text-sm font-bold">
                    {content.visual.homeTeam.slice(0, 2).toUpperCase()}
                  </div>
                  <p class="text-base font-semibold text-white-pure">{content.visual.homeTeam}</p>
                </div>
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 shrink-0 rounded-full bg-charcoal-700 flex items-center justify-center text-white-soft text-sm font-bold">
                    {content.visual.awayTeam.slice(0, 2).toUpperCase()}
                  </div>
                  <p class="text-base font-semibold text-white-pure">{content.visual.awayTeam}</p>
                </div>
              </div>

              <p class="mt-4 text-xs text-white-muted">{content.visual.kickoff}</p>

              <!-- Prediction + confidence bar -->
              <div class="mt-6 rounded-lg bg-deep-navy-900/60 border border-deep-navy-600 p-4">
                <p class="text-xs font-medium uppercase tracking-wider text-white-muted">
                  Prediction
                </p>
                <p class="mt-1 text-lg font-bold text-pitch-green-400">{content.visual.prediction}</p>

                <div class="mt-4">
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-white-muted">Confidence</span>
                    <span class="font-mono font-semibold text-white-pure">{content.visual.confidence}%</span>
                  </div>
                  <div class="mt-2 h-2 rounded-full bg-charcoal-700 overflow-hidden">
                    <div
                      class="h-full rounded-full bg-pitch-green-500 hero-confidence-bar"
                      style={`width: ${confidenceWidth};`}
                    ></div>
                  </div>
                </div>
              </div>

              <!-- Methodology badge -->
              <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-pitch-green-500/30 bg-pitch-green-500/10 px-3 py-1 text-xs font-semibold text-pitch-green-400">
                <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 11a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" />
                </svg>
                {content.visual.methodologyBadge}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  /* Subtle float animation — 3px vertical, 4s loop */
  .hero-card-float {
    animation: hero-float 4s ease-in-out infinite;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-3px); }
  }

  /* Confidence bar pulse (1s interval) */
  .hero-confidence-bar {
    animation: bar-pulse 2s ease-in-out infinite;
    transform-origin: left;
  }

  @keyframes bar-pulse {
    0%, 100% { filter: brightness(1); }
    50%      { filter: brightness(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card-float,
    .hero-confidence-bar {
      animation: none;
    }
  }
</style>
