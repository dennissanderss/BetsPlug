---
/**
 * Homepage Hero — Section 1.
 * See docs/specs/02-homepage.md → "SECTIE 1: HERO".
 *
 * Asymmetric hero (60% copy / 40% visual on desktop). The visual
 * card pulls the highest-confidence upcoming match from the live
 * backend at build/request time, with the JSON visual block as
 * fallback when the API is unreachable.
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import PitchLinePattern from "@/components/ui/PitchLinePattern.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { HomepageContent } from "@/content/pages/homepage/types";

// Trust-strip claims map 1:1 onto these icons (positional —
// content JSON keeps the strings translatable, the icon list lives
// here so we don't have to migrate every locale's content schema).
const TRUST_ICONS: IconName[] = ["lock", "eye", "shield-check"];

interface Props {
  locale: Locale;
  content: HomepageContent["hero"];
}

const { locale, content } = Astro.props;

const secondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);

// ── Live featured-match fetch ────────────────────────────────────
// Pulls the highest-confidence upcoming pick (next 72h) from the
// public backend. Falls back to the JSON `visual` block on any
// failure so a backend hiccup never breaks the marketing site.
const API_BASE =
  import.meta.env.PUBLIC_API_BASE ?? "https://betsplug-production.up.railway.app";

const BCP47: Record<Locale, string> = {
  en: "en-GB",
  nl: "nl-NL",
  de: "de-DE",
  fr: "fr-FR",
  es: "es-ES",
  it: "it-IT",
  sw: "sw-KE",
};

function formatKickoff(iso: string, loc: Locale): string {
  try {
    return new Date(iso).toLocaleString(BCP47[loc] ?? "en-GB", {
      weekday: "long",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
  } catch {
    return iso;
  }
}

interface FeaturedMatch {
  available: boolean;
  home_team?: string | null;
  away_team?: string | null;
  home_team_logo?: string | null;
  away_team_logo?: string | null;
  league?: string | null;
  kickoff?: string | null;
  confidence?: number | null;
}

let league = content.visual.league;
let homeTeam = content.visual.homeTeam;
let awayTeam = content.visual.awayTeam;
let homeTeamLogo: string | null = null;
let awayTeamLogo: string | null = null;
let kickoff = content.visual.kickoff;
let confidencePct = content.visual.confidence;

try {
  const res = await fetch(`${API_BASE}/api/homepage/featured-match`, {
    headers: { Accept: "application/json" },
    signal: AbortSignal.timeout(10000),
  });
  if (res.ok) {
    const data = (await res.json()) as FeaturedMatch;
    if (data.available && data.home_team && data.away_team) {
      league = data.league ?? league;
      homeTeam = data.home_team;
      awayTeam = data.away_team;
      homeTeamLogo = data.home_team_logo ?? null;
      awayTeamLogo = data.away_team_logo ?? null;
      if (data.kickoff) kickoff = formatKickoff(data.kickoff, locale);
      if (typeof data.confidence === "number") {
        confidencePct = Math.round(data.confidence * 100);
      }
    }
  }
} catch {
  // Swallow — fallback values from content JSON stay in place. The
  // client-side hydration script below will replace them on the next
  // page view if/when Railway is reachable from the visitor.
}

const confidenceWidth = `${Math.max(0, Math.min(100, confidencePct))}%`;
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft
         min-h-[80vh] md:min-h-[640px] lg:min-h-[100vh]
         flex items-center"
  aria-labelledby="hero-h1"
>
  <!-- Background — radial gradient + pitch-line pattern -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background: var(--gradient-hero-dark);"
  ></div>

  <!-- Sport-DNA pitch-line pattern (subtle on landing surface) -->
  <PitchLinePattern variant="subtle" position="full" />

  <!-- Ambient pitch-green glow (top right) -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 right-[-12%] h-[560px] w-[560px] rounded-full opacity-50 blur-[100px]"
    style="background: radial-gradient(circle, rgba(0,210,106,0.40) 0%, rgba(0,210,106,0) 70%);"
  ></div>

  <Container size="xl" class="relative py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Content (60%) -->
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-pitch-green-400">
          {content.kicker}
        </p>

        <h1
          id="hero-h1"
          class="mt-4 text-4xl sm:text-5xl lg:text-6xl xl:text-[64px]
                 font-bold leading-[1.05] tracking-tight text-white-pure"
          set:html={parseAccent(content.h1)}
        ></h1>

        <p class="mt-6 max-w-2xl text-lg sm:text-xl leading-relaxed text-white-soft">
          {content.subheadline}
        </p>

        <!-- Trust strip -->
        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {content.trustStrip.map((item, i) => (
            <li>
              <USPItem
                icon={TRUST_ICONS[i] ?? "check"}
                text={item}
                size="sm"
                surface="dark"
              />
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <Button
            href={content.ctaPrimary.href}
            variant="primary"
            size="lg"
            surface="dark"
            external
          >
            {content.ctaPrimary.label}
            <svg
              slot="trailing"
              class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"
              />
            </svg>
          </Button>

          <Button
            href={secondaryHref}
            variant="secondary"
            size="lg"
            surface="dark"
          >
            {content.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <!-- Visual (40%) -->
      <div class="lg:col-span-5 lg:flex lg:justify-end">
        <div class="relative w-full max-w-md mx-auto lg:max-w-none">
          <!-- Floating motion wrapper -->
          <div class="hero-card-float">
            <!-- Prediction card mockup -->
            <div
              class="relative rounded-2xl border border-deep-navy-600
                     bg-deep-navy-800/90 backdrop-blur-sm p-6 shadow-[var(--shadow-xl)]"
              data-hero-card
              data-locale={locale}
              data-api-base={API_BASE}
            >
              <!-- Top: league + lock -->
              <div class="flex items-center justify-between text-xs">
                <span class="inline-flex items-center gap-2 rounded-full bg-deep-navy-700 px-3 py-1 font-semibold text-white-soft">
                  <span class="h-1.5 w-1.5 rounded-full bg-pitch-green-500"></span>
                  <span data-hero-league>{league}</span>
                </span>
                <span class="inline-flex items-center gap-1 text-white-muted">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z" clip-rule="evenodd" />
                  </svg>
                  {content.visual.lockLabel}
                </span>
              </div>

              <!-- Teams -->
              <div class="mt-6 space-y-3">
                <div class="flex items-center gap-3" data-hero-home-row>
                  {homeTeamLogo ? (
                    <img
                      src={homeTeamLogo}
                      alt={`${homeTeam} logo`}
                      width="40"
                      height="40"
                      loading="lazy"
                      decoding="async"
                      class="h-10 w-10 shrink-0 object-contain"
                      data-hero-home-logo
                    />
                  ) : (
                    <div
                      class="h-10 w-10 shrink-0 rounded-full bg-charcoal-700 flex items-center justify-center text-white-soft text-sm font-bold"
                      data-hero-home-initial
                    >
                      {homeTeam.slice(0, 2).toUpperCase()}
                    </div>
                  )}
                  <p class="text-base font-semibold text-white-pure" data-hero-home-name>{homeTeam}</p>
                </div>
                <div class="flex items-center gap-3" data-hero-away-row>
                  {awayTeamLogo ? (
                    <img
                      src={awayTeamLogo}
                      alt={`${awayTeam} logo`}
                      width="40"
                      height="40"
                      loading="lazy"
                      decoding="async"
                      class="h-10 w-10 shrink-0 object-contain"
                      data-hero-away-logo
                    />
                  ) : (
                    <div
                      class="h-10 w-10 shrink-0 rounded-full bg-charcoal-700 flex items-center justify-center text-white-soft text-sm font-bold"
                      data-hero-away-initial
                    >
                      {awayTeam.slice(0, 2).toUpperCase()}
                    </div>
                  )}
                  <p class="text-base font-semibold text-white-pure" data-hero-away-name>{awayTeam}</p>
                </div>
              </div>

              <p class="mt-4 text-xs text-white-muted" data-hero-kickoff>{kickoff}</p>

              <!-- Confidence bar -->
              <div class="mt-6 rounded-lg bg-deep-navy-900/60 border border-deep-navy-600 p-4">
                <div class="flex items-center justify-between text-xs">
                  <span class="text-white-muted">Confidence</span>
                  <span class="font-mono font-semibold text-white-pure" data-hero-confidence-pct>{confidencePct}%</span>
                </div>
                <div class="mt-2 h-2 rounded-full bg-charcoal-700 overflow-hidden">
                  <div
                    class="h-full rounded-full bg-pitch-green-500 hero-confidence-bar"
                    style={`width: ${confidenceWidth};`}
                    data-hero-confidence-bar
                  ></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  /* Subtle float animation — 3px vertical, 4s loop */
  .hero-card-float {
    animation: hero-float 4s ease-in-out infinite;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-3px); }
  }

  /* Confidence bar pulse (1s interval) */
  .hero-confidence-bar {
    animation: bar-pulse 2s ease-in-out infinite;
    transform-origin: left;
  }

  @keyframes bar-pulse {
    0%, 100% { filter: brightness(1); }
    50%      { filter: brightness(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card-float,
    .hero-confidence-bar {
      animation: none;
    }
  }
</style>

<script>
  /**
   * Client-side hydration of the hero "live prediction" card.
   *
   * The Astro site is fully static — pages are rebuilt only when we
   * push to main. Without this script, a visitor would see whatever
   * data was current at the last build (or, worse, the JSON fallback
   * if the build-time fetch happened to fail). On every page view we
   * refetch the live featured-match and update the card in place so
   * the UI never lags behind the engine.
   */
  (function () {
    const card = document.querySelector("[data-hero-card]");
    if (!card) return;

    const apiBase = card.getAttribute("data-api-base") ?? "";
    const locale = card.getAttribute("data-locale") ?? "en";
    if (!apiBase) return;

    const BCP47: Record<string, string> = {
      en: "en-GB",
      nl: "nl-NL",
      de: "de-DE",
      fr: "fr-FR",
      es: "es-ES",
      it: "it-IT",
      sw: "sw-KE",
    };

    function formatKickoff(iso: string): string {
      try {
        return new Date(iso).toLocaleString(BCP47[locale] ?? "en-GB", {
          weekday: "long",
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
        });
      } catch {
        return iso;
      }
    }

    function setText(selector: string, value: string) {
      const el = card!.querySelector<HTMLElement>(selector);
      if (el) el.textContent = value;
    }

    function replaceLogo(rowSelector: string, logoUrl: string | null, name: string, isHome: boolean) {
      const row = card!.querySelector<HTMLElement>(rowSelector);
      if (!row) return;
      const initialKey = isHome ? "[data-hero-home-initial]" : "[data-hero-away-initial]";
      const logoKey = isHome ? "[data-hero-home-logo]" : "[data-hero-away-logo]";
      const initialEl = row.querySelector<HTMLElement>(initialKey);
      const logoEl = row.querySelector<HTMLImageElement>(logoKey);
      const initials = name.slice(0, 2).toUpperCase();

      if (logoUrl) {
        if (logoEl) {
          logoEl.src = logoUrl;
          logoEl.alt = `${name} logo`;
        } else if (initialEl) {
          // Replace the initial-badge div with an <img>
          const img = document.createElement("img");
          img.src = logoUrl;
          img.alt = `${name} logo`;
          img.width = 40;
          img.height = 40;
          img.loading = "lazy";
          img.decoding = "async";
          img.className = "h-10 w-10 shrink-0 object-contain";
          img.setAttribute(isHome ? "data-hero-home-logo" : "data-hero-away-logo", "");
          initialEl.replaceWith(img);
        }
      } else {
        // No logo URL — make sure we render the initial-badge fallback
        if (initialEl) {
          initialEl.textContent = initials;
        } else if (logoEl) {
          const div = document.createElement("div");
          div.className =
            "h-10 w-10 shrink-0 rounded-full bg-charcoal-700 flex items-center justify-center text-white-soft text-sm font-bold";
          div.textContent = initials;
          div.setAttribute(isHome ? "data-hero-home-initial" : "data-hero-away-initial", "");
          logoEl.replaceWith(div);
        }
      }
    }

    interface FeaturedMatch {
      available: boolean;
      home_team?: string | null;
      away_team?: string | null;
      home_team_logo?: string | null;
      away_team_logo?: string | null;
      league?: string | null;
      kickoff?: string | null;
      confidence?: number | null;
    }

    async function hydrate() {
      try {
        const res = await fetch(`${apiBase}/api/homepage/featured-match`, {
          headers: { Accept: "application/json" },
        });
        if (!res.ok) return;
        const data = (await res.json()) as FeaturedMatch;
        if (!data.available || !data.home_team || !data.away_team) return;

        if (data.league) setText("[data-hero-league]", data.league);
        setText("[data-hero-home-name]", data.home_team);
        setText("[data-hero-away-name]", data.away_team);
        if (data.kickoff) setText("[data-hero-kickoff]", formatKickoff(data.kickoff));

        if (typeof data.confidence === "number") {
          const pct = Math.max(0, Math.min(100, Math.round(data.confidence * 100)));
          setText("[data-hero-confidence-pct]", `${pct}%`);
          const bar = card!.querySelector<HTMLElement>("[data-hero-confidence-bar]");
          if (bar) bar.style.width = `${pct}%`;
        }

        replaceLogo("[data-hero-home-row]", data.home_team_logo ?? null, data.home_team, true);
        replaceLogo("[data-hero-away-row]", data.away_team_logo ?? null, data.away_team, false);
      } catch {
        // Network error or backend down — leave whatever the build-time
        // fetch produced (real data on a healthy build, JSON fallback
        // on a failed build).
      }
    }

    hydrate();
  })();
</script>
