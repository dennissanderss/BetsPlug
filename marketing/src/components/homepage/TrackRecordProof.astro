---
/**
 * Homepage TrackRecordProof — Section 5.
 * See docs/specs/02-homepage.md → "SECTIE 5: TRACK RECORD PROOF".
 *
 * Single-column centered proof section. Visualisation is a 30-day
 * grid of color-coded squares (sample), legend below. No specific
 * win-rate claim — per spec we never publish accuracy %.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { HomepageContent } from "@/content/pages/homepage/types";

interface Props {
  locale: Locale;
  content: HomepageContent["trackRecord"];
}

const { locale, content } = Astro.props;

const ctaHref = getLocalizedPath(content.cta.canonical, locale);

// Build a 30-day deterministic illustrative grid. Pattern is fixed
// (not pseudo-random) so the visual never implies a real outcome
// distribution. Colors map: 0 = pending, 1 = win, 2 = loss, 3 = void.
// TODO: replace with real track-record summary from app.betsplug.com
const sampleGrid = [
  1, 1, 2, 1, 1, 0, 1, 2, 1, 1,
  1, 0, 2, 1, 3, 1, 1, 2, 1, 1,
  0, 1, 1, 2, 1, 1, 0, 1, 1, 1,
];

const colorMap: Record<number, string> = {
  0: "bg-charcoal-500",         // pending
  1: "bg-pitch-green-500",      // win
  2: "bg-danger",               // loss
  3: "bg-warning",              // void
};
---

<Section surface="light" spacing="lg" ariaLabelledby="track-record-h2">
  <Container size="md">
    <div class="text-center">
      <h2
        id="track-record-h2"
        class="text-3xl sm:text-4xl lg:text-[44px] font-bold leading-tight tracking-tight text-charcoal-900"
      >
        {content.h2}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-charcoal-700 max-w-2xl mx-auto">
        {content.body}
      </p>
    </div>

    <!-- Top-line summary -->
    <div class="mt-12 rounded-2xl border border-stadium-white-200 bg-stadium-white-50 p-6 lg:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-medium uppercase tracking-wider text-charcoal-500">
            {content.topLineLabel}
          </p>
          <p class="mt-1 text-base lg:text-lg font-semibold text-charcoal-900">
            {content.topLineValue}
          </p>
        </div>

        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-600
                 hover:text-pitch-green-500 transition-colors duration-150
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400
                 focus-visible:ring-offset-2 focus-visible:ring-offset-stadium-white-50 rounded-md"
        >
          {content.cta.label}
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
      </div>

      <!-- 30-day grid -->
      <div
        class="mt-6 grid grid-cols-15 gap-1.5"
        role="img"
        aria-label="30 day prediction grid sample"
      >
        {sampleGrid.map((status) => (
          <div
            class={`aspect-square rounded ${colorMap[status]}`}
            aria-hidden="true"
          ></div>
        ))}
      </div>

      <!-- Legend -->
      <ul class="mt-5 flex flex-wrap items-center gap-4 text-xs text-charcoal-700">
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-pitch-green-500" aria-hidden="true"></span>
          {content.legend.win}
        </li>
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-danger" aria-hidden="true"></span>
          {content.legend.loss}
        </li>
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-warning" aria-hidden="true"></span>
          {content.legend.void}
        </li>
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-charcoal-500" aria-hidden="true"></span>
          {content.legend.pending}
        </li>
      </ul>
    </div>
  </Container>
</Section>

<style>
  /* Custom 15-column grid for 30-day strip (15 wide × 2 rows). */
  .grid-cols-15 {
    grid-template-columns: repeat(15, minmax(0, 1fr));
  }
</style>
