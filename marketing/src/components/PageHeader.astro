---
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
}
const { kicker, title, subtitle } = Astro.props;
---

<section
  class="relative mx-auto max-w-7xl px-4 pt-16 pb-8 sm:px-6 sm:pt-20 lg:px-8"
>
  <div
    aria-hidden
    class="glow-blob"
    style="top:60px;right:-60px;width:420px;height:420px;background:hsl(142 71% 45% / 0.18);"
  >
  </div>
  <div class="relative max-w-3xl">
    {
      kicker && (
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent-green-bright)]">
          {kicker}
        </p>
      )
    }
    <h1
      class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl"
    >
      <Fragment set:html={title} />
    </h1>
    {
      subtitle && (
        <p class="mt-4 text-base text-[var(--color-text-muted)] sm:text-lg">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
