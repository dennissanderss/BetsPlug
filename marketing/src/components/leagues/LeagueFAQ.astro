---
/**
 * LeagueFAQ — Section 6 of /predictions/{league}.
 * 5-6 league-specific accordion questions. Native <details>.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { LeaguePageContent } from "@/content/leagues/types";

interface Props {
  locale: Locale;
  content: LeaguePageContent["faq"];
}

const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="dark" spacing="lg" ariaLabelledby="league-faq-h2">
  <Container size="md">
    <header class="text-center">
      <h2 id="league-faq-h2" class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure">
        {content.h2}
      </h2>
    </header>

    <div class="mt-12 divide-y divide-deep-navy-600 rounded-2xl border border-deep-navy-600 bg-charcoal-700">
      {content.questions.map((item) => (
        <details class="group" name="league-faq">
          <summary class="flex items-center justify-between gap-4 cursor-pointer px-6 py-5 list-none text-left focus-visible:outline-none focus-visible:bg-deep-navy-800 rounded-2xl">
            <span class="text-base lg:text-lg font-semibold text-white-pure">{item.q}</span>
            <svg class="h-5 w-5 shrink-0 text-white-muted transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-base leading-relaxed text-white-soft">{item.a}</div>
        </details>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href={ctaHref} class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-400 hover:text-pitch-green-300 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2 focus-visible:ring-offset-deep-navy-900 rounded-md">
        {content.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </Container>
</Section>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ""; }
</style>
