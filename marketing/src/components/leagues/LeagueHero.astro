---
/**
 * LeagueHero — Section 1 of /predictions/{league}.
 * 60/40 desktop split: copy left, league-stats panel right with the
 * league's primary color as accent. CTA varies by isTopThree:
 *   - top-3:  "View Free Predictions" anchor scroll
 *   - others: "Unlock {LEAGUE} Predictions" → /pricing
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import ScoreNumber from "@/components/ui/ScoreNumber.astro";
import GlowOrb from "@/components/ui/GlowOrb.astro";
import StadiumLightArc from "@/components/ui/StadiumLightArc.astro";
import AccentGrid from "@/components/ui/AccentGrid.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { LeagueConfig } from "@/config/leagues";
import { leagueLogoUrl } from "@/config/leagues";
import type { LeaguePageContent } from "@/content/leagues/types";

interface Props {
  locale: Locale;
  league: LeagueConfig;
  content: LeaguePageContent["hero"];
  /** Real number from API (or 0 fallback). */
  predictionsThisWeek: number;
  currentMatchweek: number;
}

const { locale, league, content, predictionsThisWeek, currentMatchweek } = Astro.props;

const pricingHref = getLocalizedPath("pricing", locale);
const methodologyHref = getLocalizedPath(content.ctaSecondary.canonical, locale);

const ctaPrimaryLabel = league.isTopThree
  ? content.ctaPrimaryFreeLabel
  : content.ctaPrimaryGatedLabel;
const ctaPrimaryHref = league.isTopThree ? "#league-cards" : pricingHref;

const trustStripWeek = content.trustStripPredictionsThisWeek.replace(
  "{count}",
  String(predictionsThisWeek),
);
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[35vh] py-14 md:py-20 isolate"
  aria-labelledby="league-hero-h1"
>
  <!-- Atmospheric base mesh -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background: var(--gradient-hero-atmospheric);"
  ></div>
  <!-- League-color accent gradient over the base — keeps the per-league brand tint -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style={`background: linear-gradient(135deg, ${league.primaryColor}22 0%, transparent 60%);`}
  ></div>
  <StadiumLightArc position="top-center" intensity="medium" />
  <GlowOrb size="xl" color="pitch-green" position="top-right"   intensity="medium" blur={120} />
  <GlowOrb size="md" color="navy"        position="bottom-left" intensity="medium" blur={100} />
  <AccentGrid variant="subtle" position="top-right" fade />

  <Container size="xl" class="relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <!-- Copy (60%) -->
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em]" style={`color: ${league.primaryColor}; filter: brightness(1.4);`}>
          {league.country}
        </p>
        <h1
          id="league-hero-h1"
          class="mt-3 text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold leading-[1.05] tracking-tight text-white-pure"
        >
          {content.h1}
        </h1>
        <p class="mt-5 max-w-2xl text-base sm:text-lg leading-relaxed text-white-soft">
          {content.subheadline}
        </p>

        <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-white-soft">
          {[trustStripWeek, content.trustStripUpdated, content.trustStripLocked].map((item) => (
            <li class="inline-flex items-center gap-2">
              <svg class="h-4 w-4 text-pitch-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">
            {ctaPrimaryLabel}
          </Button>
          <Button href={methodologyHref} variant="secondary" size="lg" surface="dark">
            {content.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <!-- League stats panel (40%) -->
      <div class="lg:col-span-5">
        <div
          class="rounded-2xl border border-deep-navy-600 bg-deep-navy-800/70 p-6 lg:p-8"
          style={`box-shadow: 0 0 0 1px ${league.primaryColor}33 inset;`}
        >
          <!-- Big league mark -->
          <div class="flex items-center gap-4">
            <div
              class="h-16 w-16 shrink-0 rounded-2xl flex items-center justify-center p-2"
              style={`background: linear-gradient(135deg, ${league.primaryColor}33 0%, ${league.primaryColor}1a 100%); box-shadow: 0 0 0 1px ${league.primaryColor}55 inset;`}
              aria-hidden="true"
            >
              <img
                src={leagueLogoUrl(league)}
                alt=""
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-contain"
              />
            </div>
            <div>
              <p class="text-base font-bold text-white-pure">{league.name}</p>
              <p class="text-xs text-white-muted">{league.country} · {league.season}</p>
            </div>
          </div>

          <dl class="mt-6 grid grid-cols-3 gap-3">
            <div class="flex flex-col items-center gap-2 rounded-lg border border-deep-navy-600 bg-deep-navy-900 p-3 text-center">
              <dt class="text-[10px] font-medium uppercase tracking-wider text-white-muted">{content.statsTeams}</dt>
              <dd class="mt-0">
                <ScoreNumber value={league.teams} size="md" variant="default" />
              </dd>
            </div>
            <div class="flex flex-col items-center gap-2 rounded-lg border border-deep-navy-600 bg-deep-navy-900 p-3 text-center">
              <dt class="text-[10px] font-medium uppercase tracking-wider text-white-muted">{content.statsMatchweek}</dt>
              <dd class="mt-0">
                <ScoreNumber value={currentMatchweek} size="md" variant="default" />
              </dd>
            </div>
            <div class="flex flex-col items-center gap-2 rounded-lg border border-deep-navy-600 bg-deep-navy-900 p-3 text-center">
              <dt class="text-[10px] font-medium uppercase tracking-wider text-white-muted">{content.statsThisWeek}</dt>
              <dd class="mt-0">
                <ScoreNumber value={predictionsThisWeek} size="md" variant="highlight" />
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </Container>
</section>
