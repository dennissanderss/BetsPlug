---
/**
 * TopTeamsGrid — Section 4 of /predictions/{league}.
 * Top 5-8 teams for the league. Live data (position, form) comes from
 * the per-league API. Falls back to placeholder dashes when missing.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import type { LeagueConfig } from "@/config/leagues";
import type { LeaguePageContent } from "@/content/leagues/types";

interface TopTeam {
  slug: string;
  name: string;
  logo?: string;
  currentPosition?: number;
  recentForm?: string;
}

interface Props {
  league: LeagueConfig;
  content: LeaguePageContent["topTeams"];
  topTeams: TopTeam[];
}

const { league, content, topTeams } = Astro.props;

// Show 8 for big leagues (Premier League, La Liga), 5 for smaller.
const limit = league.teams >= 20 ? 8 : 5;
const display = topTeams.slice(0, limit);
---

<Section surface="dark" spacing="lg" ariaLabelledby="top-teams-h2">
  <Container size="xl">
    <header>
      <h2
        id="top-teams-h2"
        class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure"
      >
        {content.h2}
      </h2>
    </header>

    <ul class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" role="list">
      {display.map((team) => (
        <li>
          <a
            href={`https://app.betsplug.com/teams/${team.slug}`}
            class="block rounded-xl border border-deep-navy-600 bg-charcoal-700 p-4
                   transition-all duration-200 hover:border-pitch-green-500/40
                   hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5
                   focus-visible:outline-none focus-visible:ring-2
                   focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
                   focus-visible:ring-offset-deep-navy-900"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div
              class="h-10 w-10 rounded-full flex items-center justify-center text-white font-bold text-xs"
              style={`background-color: ${league.primaryColor};`}
              aria-hidden="true"
            >
              {team.name.split(" ").map((w) => w[0]).slice(0, 2).join("")}
            </div>
            <p class="mt-3 text-sm font-bold text-white-pure truncate">{team.name}</p>
            <dl class="mt-3 space-y-1 text-xs">
              <div class="flex items-center justify-between">
                <dt class="text-white-muted">{content.positionLabel}</dt>
                <dd class="font-mono font-semibold text-white-soft">
                  {team.currentPosition ? `#${team.currentPosition}` : "—"}
                </dd>
              </div>
              <div class="flex items-center justify-between">
                <dt class="text-white-muted">{content.formLabel}</dt>
                <dd class="font-mono font-semibold text-pitch-green-400">
                  {team.recentForm ?? "—"}
                </dd>
              </div>
            </dl>
            <p class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-pitch-green-400">
              {content.viewTeamLabel}
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </p>
          </a>
        </li>
      ))}
    </ul>
  </Container>
</Section>
