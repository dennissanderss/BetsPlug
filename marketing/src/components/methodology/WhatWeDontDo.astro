---
import type { MethodologyContent } from "@/content/pages/methodology/types";

interface Props {
  content: MethodologyContent["whatWeDontDo"];
}
const { content } = Astro.props;
---

<section id="what-we-dont-do" class="scroll-mt-24 mt-16">
  <h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900">
    {content.h2}
  </h2>
  <p class="mt-5 text-lg leading-relaxed text-charcoal-700">{content.intro}</p>

  <ul class="mt-8 space-y-4">
    {content.items.map((item) => (
      <li class="flex items-start gap-4 rounded-xl border border-stadium-white-200 bg-white p-5 shadow-[var(--shadow-sm)]">
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-danger/10 text-danger" aria-hidden="true">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </span>
        <div>
          <h3 class="text-base font-bold text-charcoal-900">{item.title}</h3>
          <p class="mt-1 text-sm leading-relaxed text-charcoal-700">{item.detail}</p>
        </div>
      </li>
    ))}
  </ul>
</section>
