---
/**
 * PoissonDiagram — overlapping probability mass functions for two
 * teams' goal expectations. X-axis: goals 0..6, Y-axis: probability.
 * Pure SVG curves drawn from analytic Poisson formula λ^k e^-λ / k!
 */
interface Props {
  caption: string;
  surface?: "light" | "dark";
}
const { caption, surface = "dark" } = Astro.props;

const fg     = surface === "dark" ? "rgb(232,234,239)" : "rgb(15,20,25)";
const muted  = surface === "dark" ? "rgb(155,163,181)" : "rgb(90,100,120)";
const accent = "#00d26a";
const blue   = "#3b82f6";

// Compute Poisson PMF P(k|λ)
function poisson(k: number, lambda: number): number {
  let fact = 1;
  for (let i = 1; i <= k; i++) fact *= i;
  return (lambda ** k) * Math.exp(-lambda) / fact;
}

// Two teams: home λ=2.4, away λ=0.9
const homeLambda = 2.4;
const awayLambda = 0.9;

// Plot area
const W = 720, H = 340;
const padL = 60, padR = 30, padT = 40, padB = 60;
const plotW = W - padL - padR;
const plotH = H - padT - padB;

const xMax = 6; // goals 0..6
const yMax = 0.45; // probability axis

// Compute bar/dot positions
const homePoints = Array.from({ length: xMax + 1 }, (_, k) => ({
  k, p: poisson(k, homeLambda),
}));
const awayPoints = Array.from({ length: xMax + 1 }, (_, k) => ({
  k, p: poisson(k, awayLambda),
}));

const xScale = (k: number) => padL + (k / xMax) * plotW;
const yScale = (p: number) => padT + plotH - (p / yMax) * plotH;
---

<figure class="my-8">
  <div class={`rounded-2xl border ${surface === "dark" ? "border-deep-navy-600 bg-deep-navy-800/60" : "border-stadium-white-200 bg-white"} p-6 lg:p-8`}>
    <svg viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <!-- Y axis -->
      <line x1={padL} y1={padT} x2={padL} y2={padT + plotH} stroke={muted} stroke-width="1"/>
      {[0, 0.1, 0.2, 0.3, 0.4].map((p) => (
        <g>
          <line x1={padL} y1={yScale(p)} x2={padL + plotW} y2={yScale(p)} stroke={muted} stroke-opacity="0.15"/>
          <text x={padL - 8} y={yScale(p) + 4} font-family="Geist Mono, ui-monospace, monospace" font-size="10" text-anchor="end" fill={muted}>{p.toFixed(1)}</text>
        </g>
      ))}
      <text x={padL - 30} y={padT + plotH / 2} font-family="Inter, sans-serif" font-size="11" font-weight="600" fill={muted} transform={`rotate(-90 ${padL - 30} ${padT + plotH / 2})`}>P(goals)</text>

      <!-- X axis -->
      <line x1={padL} y1={padT + plotH} x2={padL + plotW} y2={padT + plotH} stroke={muted} stroke-width="1"/>
      {homePoints.map(({ k }) => (
        <text x={xScale(k)} y={padT + plotH + 18} font-family="Geist Mono, ui-monospace, monospace" font-size="11" text-anchor="middle" fill={muted}>{k}</text>
      ))}
      <text x={padL + plotW / 2} y={padT + plotH + 42} font-family="Inter, sans-serif" font-size="11" font-weight="600" text-anchor="middle" fill={muted}>Goals scored</text>

      <!-- Home curve (λ=2.4) — area + line -->
      <path
        d={`M ${homePoints.map(({ k, p }) => `${xScale(k)},${yScale(p)}`).join(" L ")}`}
        fill="none" stroke={accent} stroke-width="2"
      />
      {homePoints.map(({ k, p }) => (
        <circle cx={xScale(k)} cy={yScale(p)} r="4" fill={accent} />
      ))}

      <!-- Away curve (λ=0.9) -->
      <path
        d={`M ${awayPoints.map(({ k, p }) => `${xScale(k)},${yScale(p)}`).join(" L ")}`}
        fill="none" stroke={blue} stroke-width="2" stroke-dasharray="4 3"
      />
      {awayPoints.map(({ k, p }) => (
        <circle cx={xScale(k)} cy={yScale(p)} r="3.5" fill={blue} />
      ))}

      <!-- Legend -->
      <g>
        <rect x={padL + plotW - 200} y={padT + 10} width="190" height="60" rx="8" fill={surface === "dark" ? "rgba(10,14,31,0.7)" : "rgba(255,255,255,0.9)"} stroke={muted} stroke-opacity="0.3"/>
        <line x1={padL + plotW - 188} y1={padT + 30} x2={padL + plotW - 168} y2={padT + 30} stroke={accent} stroke-width="2"/>
        <circle cx={padL + plotW - 178} cy={padT + 30} r="3" fill={accent}/>
        <text x={padL + plotW - 160} y={padT + 33} font-family="Inter, sans-serif" font-size="11" fill={fg}>Home (λ = 2.4)</text>
        <line x1={padL + plotW - 188} y1={padT + 53} x2={padL + plotW - 168} y2={padT + 53} stroke={blue} stroke-width="2" stroke-dasharray="4 3"/>
        <circle cx={padL + plotW - 178} cy={padT + 53} r="3" fill={blue}/>
        <text x={padL + plotW - 160} y={padT + 56} font-family="Inter, sans-serif" font-size="11" fill={fg}>Away (λ = 0.9)</text>
      </g>
    </svg>
  </div>
  <figcaption class={`mt-3 text-center text-sm ${surface === "dark" ? "text-white-muted" : "text-charcoal-500"}`}>
    {caption}
  </figcaption>
</figure>
