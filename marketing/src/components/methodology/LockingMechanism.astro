---
import LockingTimeline from "@/components/methodology/diagrams/LockingTimeline.astro";
import type { MethodologyContent } from "@/content/pages/methodology/types";

interface Props {
  content: MethodologyContent["locking"];
}
const { content } = Astro.props;
---

<section id="locking" class="scroll-mt-24 mt-16">
  <h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900">
    {content.h2}
  </h2>
  <div class="mt-5 space-y-5 text-base lg:text-[17px] leading-relaxed text-charcoal-700">
    {content.paragraphs.map((p) => <p>{p}</p>)}
  </div>

  <LockingTimeline caption={content.timelineCaption} steps={content.timelineSteps} surface="light" />
</section>
