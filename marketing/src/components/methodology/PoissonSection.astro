---
import PoissonDiagram from "@/components/methodology/diagrams/PoissonDiagram.astro";
import katex from "katex";
import type { MethodologyContent } from "@/content/pages/methodology/types";

interface Props {
  content: MethodologyContent["poisson"];
}
const { content } = Astro.props;

const formula = katex.renderToString(
  "P(k\\,;\\,\\lambda) = \\dfrac{\\lambda^{k} e^{-\\lambda}}{k!}",
  { throwOnError: false, displayMode: true },
);
---

<section id="poisson" class="scroll-mt-24 mt-16">
  <h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900">
    {content.h2}
  </h2>
  <div class="mt-5 space-y-5 text-base lg:text-[17px] leading-relaxed text-charcoal-700">
    {content.paragraphs.map((p) => <p>{p}</p>)}
  </div>

  <div class="mt-6 rounded-xl border border-stadium-white-200 bg-stadium-white-50 p-5 text-center" set:html={formula}></div>

  <PoissonDiagram caption={content.formulaCaption} surface="light" />

  <aside class="mt-6 rounded-xl border-l-4 border-pitch-green-500 bg-pitch-green-500/5 p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-pitch-green-700">{content.exampleBoxLabel}</p>
    <p class="mt-2 text-sm leading-relaxed text-charcoal-900">{content.exampleBoxBody}</p>
  </aside>
</section>
