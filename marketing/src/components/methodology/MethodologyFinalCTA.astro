---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { MethodologyContent } from "@/content/pages/methodology/types";

interface Props {
  locale: Locale;
  content: MethodologyContent["finalCta"];
}
const { locale, content } = Astro.props;
const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<Section surface="conversion" spacing="xl" ariaLabelledby="methodology-final-cta-h2">
  <div aria-hidden="true" class="pointer-events-none absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-30 blur-[120px]" style="background: radial-gradient(circle, rgba(0,210,106,0.45) 0%, rgba(0,210,106,0) 70%);"></div>

  <Container size="md" class="relative">
    <div class="text-center">
      <h2 id="methodology-final-cta-h2" class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight tracking-tight text-white-pure">
        {content.h2}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-white-soft">{content.body}</p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">{content.ctaPrimary.label}</Button>
        <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">{content.ctaSecondary.label}</Button>
      </div>
    </div>
  </Container>
</Section>
