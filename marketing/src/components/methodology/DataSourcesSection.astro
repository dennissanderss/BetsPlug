---
import type { MethodologyContent } from "@/content/pages/methodology/types";

interface Props {
  content: MethodologyContent["data"];
}
const { content } = Astro.props;
---

<section id="data" class="scroll-mt-24 mt-16">
  <h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900">
    {content.h2}
  </h2>

  <div class="mt-5 grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-5 text-base lg:text-[17px] leading-relaxed text-charcoal-700">
      {content.paragraphs.map((p) => <p>{p}</p>)}
    </div>

    <aside class="rounded-xl border border-stadium-white-200 bg-stadium-white-50 p-5">
      <h3 class="text-sm font-bold uppercase tracking-wider text-charcoal-500">{content.panelTitle}</h3>
      <ul class="mt-4 space-y-3 text-sm">
        {content.panelItems.map((item) => (
          <li class="flex items-start gap-2">
            <svg class="h-4 w-4 text-pitch-green-600 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-charcoal-700">{item}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>
