---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import GlowOrb from "@/components/ui/GlowOrb.astro";
import StadiumLightArc from "@/components/ui/StadiumLightArc.astro";
import AccentGrid from "@/components/ui/AccentGrid.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { MethodologyContent } from "@/content/pages/methodology/types";

const TRUST_ICONS: IconName[] = ["book-open", "git-compare", "lock"];

interface Props {
  locale: Locale;
  content: MethodologyContent["hero"];
}
const { locale, content } = Astro.props;
const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[40vh] py-16 md:py-20 isolate" aria-labelledby="methodology-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-atmospheric);"></div>
  <StadiumLightArc position="top-center" intensity="low" />
  <GlowOrb size="xl" color="pitch-green" position="top-right" intensity="medium" blur={120} />
  <GlowOrb size="md" color="navy"        position="bottom-left" intensity="medium" blur={100} />
  <AccentGrid variant="subtle" position="top-right" fade />

  <Container size="md" class="relative z-10 text-center">
    <h1 id="methodology-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold leading-[1.05] tracking-tight text-white-pure" set:html={parseAccent(content.h1)}></h1>
    <p class="mt-6 text-lg sm:text-xl leading-relaxed text-white-soft max-w-2xl mx-auto">
      {content.subheadline}
    </p>

    <ul class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3 text-sm">
      {content.trustStrip.map((item, i) => (
        <li>
          <USPItem
            icon={TRUST_ICONS[i] ?? "check"}
            text={item}
            size="sm"
            surface="dark"
          />
        </li>
      ))}
    </ul>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">{content.ctaPrimary.label}</Button>
      <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">{content.ctaSecondary.label}</Button>
    </div>
  </Container>
</section>
