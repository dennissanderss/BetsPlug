---
/**
 * PredictionsHero — Section 1 of /predictions hub.
 * 60/40 desktop split: copy left, mini track-record visual right.
 * Live indicator counts seconds since last update via tiny inline JS.
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { localeBcp47 } from "@/i18n/locales";
import type { PredictionsHubContent } from "@/content/pages/predictions/types";

const TRUST_ICONS: IconName[] = ["zap", "lock", "eye"];

interface Props {
  locale: Locale;
  content: PredictionsHubContent["hero"];
  /** Today's date — pre-formatted in caller for cache stability. */
  formattedDate: string;
  /** Last-updated ISO from API. */
  lastUpdated: string;
}

const { locale, content, formattedDate, lastUpdated } = Astro.props;

const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
const trackRecordHref = getLocalizedPath("track-record", locale);

const h1 = content.h1Template.replace("{date}", formattedDate);

// Deterministic illustrative 30-day grid for the visual (mirrors
// homepage TrackRecordProof legend). 0=pending,1=win,2=loss,3=void.
const sample = [
  1, 1, 2, 1, 1, 0, 1, 2, 1, 1,
  1, 0, 2, 1, 3, 1, 1, 2, 1, 1,
  0, 1, 1, 2, 1, 1, 0, 1, 1, 1,
];
const colorMap: Record<number, string> = {
  0: "bg-charcoal-500",
  1: "bg-pitch-green-500",
  2: "bg-danger",
  3: "bg-warning",
};
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[40vh] py-16 md:py-20"
  aria-labelledby="predictions-hero-h1"
  data-locale={locale}
  data-bcp47={localeBcp47[locale]}
>
  <!-- Background gradient + glow -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background: var(--gradient-hero-dark);"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-24 right-[-10%] h-[480px] w-[480px] rounded-full opacity-40 blur-[100px]"
    style="background: radial-gradient(circle, rgba(0,210,106,0.40) 0%, rgba(0,210,106,0) 70%);"
  ></div>

  <Container size="xl" class="relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <!-- Copy (60%) -->
      <div class="lg:col-span-7">
        <!-- Live indicator -->
        <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-wider text-pitch-green-400">
          <span class="relative flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-pitch-green-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-pitch-green-500"></span>
          </span>
          <span>
            {content.liveLabel}
            <span data-live-seconds data-last-updated={lastUpdated}>0</span>s ago
          </span>
        </div>

        <h1
          id="predictions-hero-h1"
          class="mt-4 text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold leading-[1.05] tracking-tight text-white-pure"
        >
          {h1}
        </h1>
        <p class="mt-6 max-w-2xl text-base sm:text-lg leading-relaxed text-white-soft">
          {content.subheadline}
        </p>

        <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {content.trustStrip.map((item, i) => (
            <li>
              <USPItem
                icon={TRUST_ICONS[i] ?? "check"}
                text={item}
                size="sm"
                surface="dark"
              />
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">
            {content.ctaPrimary.label}
          </Button>
          <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">
            {content.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <!-- Visual: mini track record (40%) -->
      <div class="lg:col-span-5">
        <a
          href={trackRecordHref}
          class="block rounded-2xl border border-deep-navy-600 bg-deep-navy-800/70 p-5 lg:p-6
                 hover:border-pitch-green-500/40 hover:shadow-[var(--shadow-md)]
                 transition-all duration-200
                 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
                 focus-visible:ring-offset-deep-navy-900"
        >
          <div class="flex items-center justify-between">
            <p class="text-xs font-semibold uppercase tracking-wider text-pitch-green-400">
              {content.miniRecord.title}
            </p>
            <svg class="h-4 w-4 text-white-muted" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </div>
          <p class="mt-2 text-sm text-white-soft">{content.miniRecord.subtitle}</p>

          <div class="mt-4 grid grid-cols-15 gap-1" role="img" aria-label="30 day prediction grid sample">
            {sample.map((s) => (
              <div class={`aspect-square rounded ${colorMap[s]}`} aria-hidden="true"></div>
            ))}
          </div>

          <ul class="mt-4 flex items-center gap-3 text-[11px] text-white-muted">
            <li class="inline-flex items-center gap-1">
              <span class="h-2.5 w-2.5 rounded bg-pitch-green-500" aria-hidden="true"></span>
              {content.miniRecord.legendWin}
            </li>
            <li class="inline-flex items-center gap-1">
              <span class="h-2.5 w-2.5 rounded bg-danger" aria-hidden="true"></span>
              {content.miniRecord.legendLoss}
            </li>
          </ul>
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .grid-cols-15 { grid-template-columns: repeat(15, minmax(0, 1fr)); }
</style>

<script>
  // Live "X seconds ago" counter — driven from data-last-updated.
  (function () {
    const el = document.querySelector("[data-live-seconds]") as HTMLElement | null;
    if (!el) return;
    const lastIso = el.getAttribute("data-last-updated");
    const last = lastIso ? new Date(lastIso).getTime() : Date.now();

    function tick() {
      if (!el) return;
      const sec = Math.max(0, Math.floor((Date.now() - last) / 1000));
      el.textContent = String(sec);
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
