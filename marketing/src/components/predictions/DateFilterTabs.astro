---
/**
 * DateFilterTabs — Today / Tomorrow / This Week filter for predictions hub.
 * URL param-driven: /predictions?date=tomorrow|week (default: today).
 *
 * Each tab is a real <a href> so crawlers + JS-disabled users see the
 * correct content for every filter state.
 *
 * Auth gate (2026-05-05): "Tomorrow" and "This Week" are locked behind
 * login — they show a lock icon and route logged-out visitors to
 * app.betsplug.com/register instead of the marketing-side preview.
 * Today stays free as the conversion hook.
 */
import type { Locale } from "@/lib/i18n";
import { getLocalizedPath } from "@/lib/i18n";
import type { PredictionsHubContent } from "@/content/pages/predictions/types";

type ActiveTab = "today" | "tomorrow" | "week";

interface Props {
  locale: Locale;
  content: PredictionsHubContent["filter"];
  active: ActiveTab;
}

const { locale, content, active } = Astro.props;

const baseHref = getLocalizedPath("predictions", locale);

// Locked tabs send logged-out visitors straight to register on the app.
// The ?next param is preserved so users land back on /predictions
// after creating an account, which lets the auth flow remember their
// original intent (the dashboard already supports this).
const REGISTER_URL = "https://app.betsplug.com/register?next=/predictions";

const tabs: { key: ActiveTab; label: string; href: string; locked: boolean }[] = [
  { key: "today",    label: content.today,    href: baseHref,                  locked: false },
  { key: "tomorrow", label: content.tomorrow, href: REGISTER_URL,              locked: true  },
  { key: "week",     label: content.thisWeek, href: REGISTER_URL,              locked: true  },
];
---

<div class="flex items-center gap-1 rounded-full border border-deep-navy-600 bg-charcoal-700 p-1" role="tablist" aria-label={content.todayActiveAria}>
  {tabs.map((tab) => (
    <a
      href={tab.href}
      role="tab"
      aria-selected={tab.key === active}
      class={[
        "inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-full text-sm font-semibold transition-colors duration-150",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2 focus-visible:ring-offset-deep-navy-900",
        tab.key === active
          ? "bg-pitch-green-500 text-deep-navy-950"
          : "text-white-soft hover:text-white-pure hover:bg-white-pure/5",
      ].join(" ")}
    >
      {tab.locked && (
        <svg
          class="h-3.5 w-3.5 opacity-90"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z"
            clip-rule="evenodd"
          />
        </svg>
      )}
      {tab.label}
    </a>
  ))}
</div>
