---
/**
 * MethodologyPreview — Section 5 of /predictions hub.
 * Short methodology summary + link to full /methodology.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { PredictionsHubContent } from "@/content/pages/predictions/types";

interface Props {
  locale: Locale;
  content: PredictionsHubContent["methodology"];
}

const { locale, content } = Astro.props;

const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="dark-charcoal" spacing="lg" ariaLabelledby="hub-methodology-h2">
  <Container size="md">
    <header class="text-center">
      <h2
        id="hub-methodology-h2"
        class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure"
      >
        {content.h2}
      </h2>
    </header>

    <div class="mt-6 space-y-4 text-base sm:text-lg leading-relaxed text-white-soft">
      {content.body.map((p) => <p>{p}</p>)}
    </div>

    <ul class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4" role="list">
      {content.pillars.map((pillar) => (
        <li class="flex items-center gap-3 rounded-xl border border-deep-navy-600 bg-charcoal-700 p-4">
          <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-pitch-green-500/15 text-pitch-green-400" aria-hidden="true">
            {pillar.icon === "calc" && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="2" width="16" height="20" rx="2" />
                <line x1="8" y1="6" x2="16" y2="6" />
                <line x1="16" y1="14" x2="16" y2="18" />
                <path d="M16 10h.01" />
                <path d="M12 10h.01" />
                <path d="M8 10h.01" />
                <path d="M12 14h.01" />
                <path d="M8 14h.01" />
                <path d="M12 18h.01" />
                <path d="M8 18h.01" />
              </svg>
            )}
            {pillar.icon === "ml" && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="5" cy="6" r="2" />
                <circle cx="5" cy="18" r="2" />
                <circle cx="12" cy="12" r="2" />
                <circle cx="19" cy="6" r="2" />
                <circle cx="19" cy="18" r="2" />
                <line x1="7" y1="6" x2="10" y2="11" />
                <line x1="7" y1="18" x2="10" y2="13" />
                <line x1="14" y1="11" x2="17" y2="6" />
                <line x1="14" y1="13" x2="17" y2="18" />
              </svg>
            )}
            {pillar.icon === "lock" && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            )}
          </span>
          <p class="text-sm font-semibold text-white-soft">{pillar.label}</p>
        </li>
      ))}
    </ul>

    <div class="mt-8 text-center">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-400
               hover:text-pitch-green-300 transition-colors duration-150
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400
               focus-visible:ring-offset-2 focus-visible:ring-offset-deep-navy-900 rounded-md"
      >
        {content.cta.label}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </Container>
</Section>
