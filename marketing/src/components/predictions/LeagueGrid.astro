---
/**
 * LeagueGrid — Section 4 of /predictions hub.
 * 10 league cards, 5 per row desktop / 2 per row mobile.
 * Featured badge for the locale-relevant league (one max per locale).
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { leagueOrder, leagues } from "@/config/leagues";
import type { PredictionsHubContent } from "@/content/pages/predictions/types";

interface DailyCounts {
  /** Map of league slug → predictions today. */
  [slug: string]: number;
}

interface Props {
  locale: Locale;
  content: PredictionsHubContent["leagueGrid"];
  dailyCounts: DailyCounts;
}

const { locale, content, dailyCounts } = Astro.props;

const cards = leagueOrder.map((slug) => {
  const cfg = leagues[slug];
  const count = dailyCounts[slug] ?? 0;
  const featured = cfg.featuredFor.includes(locale);
  // /predictions/{slug} on EN, /{locale}/{folder}/{slug} on others.
  const folder = getLocalizedPath("predictions", locale).replace(/^\//, "");
  const href = locale === "en" ? `/${folder}/${slug}` : `/${folder}/${slug}`;
  return { slug, cfg, count, featured, href };
});
---

<Section surface="light" spacing="lg" ariaLabelledby="league-grid-h2">
  <Container size="xl">
    <header class="text-center max-w-2xl mx-auto">
      <h2
        id="league-grid-h2"
        class="text-3xl sm:text-4xl lg:text-[44px] font-bold leading-tight tracking-tight text-charcoal-900"
      >
        {content.h2}
      </h2>
    </header>

    <ul
      class="mt-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-5"
      role="list"
    >
      {cards.map(({ cfg, count, featured, href }) => (
        <li>
          <a
            href={href}
            class="relative block h-full rounded-xl border border-stadium-white-200 bg-white
                   p-5 text-center transition-all duration-200
                   hover:border-pitch-green-500/40 hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5
                   focus-visible:outline-none focus-visible:ring-2
                   focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
                   focus-visible:ring-offset-stadium-white-50"
          >
            {featured && (
              <span class="absolute -top-2 left-1/2 -translate-x-1/2 inline-flex items-center rounded-full bg-pitch-green-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-deep-navy-950">
                {content.featuredBadge}
              </span>
            )}

            <div
              class="mx-auto h-12 w-12 rounded-full flex items-center justify-center text-white font-bold text-sm"
              style={`background-color: ${cfg.primaryColor};`}
              aria-hidden="true"
            >
              {cfg.name.split(" ").map((w) => w[0]).slice(0, 2).join("")}
            </div>
            <p class="mt-3 text-sm font-bold text-charcoal-900">{cfg.name}</p>
            <p class="mt-0.5 text-xs text-charcoal-500">{cfg.country}</p>
            <p class="mt-3 text-[11px] font-mono font-semibold text-pitch-green-600">
              {content.todayCountTemplate.replace("{count}", String(count))}
            </p>
            <p class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-pitch-green-600">
              {content.cardCta}
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </p>
          </a>
        </li>
      ))}
    </ul>
  </Container>
</Section>
