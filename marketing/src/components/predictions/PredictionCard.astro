---
/**
 * PredictionCard — central reusable card for predictions and fixtures.
 * Used on: homepage live grid, predictions hub, all 10 league pages,
 * bet-types example, free-vs-paid comparison.
 *
 * Four variants:
 *   - "free":      everything visible
 *   - "locked":    prediction + confidence blurred, paywall overlay
 *   - "fixture":   teams + kickoff only, "Subscribe to view" link
 *   - "skeleton":  loading shimmer placeholder
 *
 * Layout (top → bottom):
 *   • Top bar:   league badge + status (lock or "Free pick")
 *   • Teams:     [logo] name — vs — [logo] name (centred grid)
 *   • Kickoff:   small clock + locale-formatted time
 *   • Body:      prediction (bold) + market label + animated confidence bar
 *
 * Visual signal: a 3px club-colour border-left ties the card to the
 * home team, breaking the uniform-border monotony when many cards
 * sit in a grid.
 */
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import TeamLogo from "@/components/ui/TeamLogo.astro";
import MatchStatusBadge from "@/components/ui/MatchStatusBadge.astro";
import { getTeamColors } from "@/config/teams";
import type { MatchStatus } from "@/lib/time";

type Variant = "free" | "locked" | "fixture" | "skeleton";

interface Team {
  name: string;
  logo?: string;     // legacy field name kept for compat with existing data
  logoUrl?: string;  // canonical name going forward
  slug?: string;
}

interface LeagueRef {
  name: string;
  slug: string;
  logo?: string;
}

interface Props {
  variant: Variant;
  locale: Locale;
  league?: LeagueRef;
  kickoff?: string;
  /** Raw ISO timestamp — when present, a small client script swaps
   *  the rendered kickoff string for a "Kickoff in 2h 34m" countdown
   *  once the match is within 24h. Server-render still uses `kickoff`
   *  so SEO/SSR text stays correct. */
  kickoffIso?: string;
  /** Optional match status — overrides the default "Free pick" / lock
   *  pill in the top bar with a LIVE/FT/HT/POSTPONED/UPCOMING badge.
   *  Leave undefined for the existing free/locked pill behaviour. */
  matchStatus?: MatchStatus;
  homeTeam?: Team;
  awayTeam?: Team;
  prediction?: string;
  /** Optional market label, e.g. "Total Goals", "Match Result". */
  market?: string;
  confidence?: number;
  matchUrl?: string;
  /** Localized labels — caller passes from content JSON. */
  labels: {
    locked: string;
    freePick: string;
    unlock: string;
    subscribeToView: string;
    viewAnalysis: string;
    confidence: string;
    lockedBeforeKickoff: string;
    viewPricing: string;
  };
  /** Extra utility classes on root. */
  class?: string;
}

const {
  variant,
  locale,
  league,
  kickoff,
  kickoffIso,
  matchStatus,
  homeTeam,
  awayTeam,
  prediction,
  market,
  confidence,
  matchUrl,
  labels,
  class: extraClass = "",
} = Astro.props;

const pricingHref = getLocalizedPath("pricing", locale);

const confidenceWidth =
  typeof confidence === "number"
    ? `${Math.max(0, Math.min(100, confidence))}%`
    : "0%";

// Club-colour border accent comes from the home team. Falls back to
// charcoal when the team isn't in our registry.
const accentColor =
  homeTeam ? getTeamColors(homeTeam.slug, homeTeam.name).primary : "#5A6478";

// Normalise team logo field — old mock data uses `logo`, new uses `logoUrl`.
const homeTeamProp = homeTeam
  ? { name: homeTeam.name, slug: homeTeam.slug, logoUrl: homeTeam.logoUrl ?? homeTeam.logo }
  : null;
const awayTeamProp = awayTeam
  ? { name: awayTeam.name, slug: awayTeam.slug, logoUrl: awayTeam.logoUrl ?? awayTeam.logo }
  : null;

const baseSurface =
  "prediction-card relative rounded-xl border bg-charcoal-700 border-deep-navy-600 " +
  "transition-all duration-200 overflow-hidden";

const cls = [baseSurface, extraClass].join(" ");
---

{variant === "skeleton" && (
  <div class={`${cls} animate-pulse h-[260px] p-5`} aria-busy="true" aria-live="polite">
    <div class="h-3 w-20 rounded bg-charcoal-700/60"></div>
    <div class="mt-6 space-y-3">
      <div class="h-4 w-3/4 rounded bg-charcoal-700/60"></div>
      <div class="h-4 w-2/3 rounded bg-charcoal-700/60"></div>
    </div>
    <div class="mt-8 h-2 w-full rounded bg-charcoal-700/60"></div>
  </div>
)}

{variant !== "skeleton" && (
  <article
    class={`${cls} group hover:border-pitch-green-500/40 hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5`}
    style={`--accent-color: ${accentColor};`}
  >
    {/* Top bar — league badge + status. matchStatus (LIVE/FT/HT/...)
        takes precedence over the variant-driven free/locked pill;
        without it we fall back to the existing free/locked pills. */}
    <header class="card-top flex items-center justify-between text-xs px-4 py-2.5">
      {league && (
        <span class="inline-flex items-center gap-1.5 font-semibold text-white-soft">
          <span class="h-1.5 w-1.5 rounded-full bg-pitch-green-500" aria-hidden="true"></span>
          {league.name}
        </span>
      )}
      {matchStatus && (
        <MatchStatusBadge status={matchStatus} />
      )}
      {!matchStatus && variant === "free" && (
        <span class="inline-flex items-center rounded-full bg-pitch-green-500/15 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-pitch-green-400">
          {labels.freePick}
        </span>
      )}
      {!matchStatus && variant === "locked" && (
        <span class="inline-flex items-center gap-1 text-white-muted">
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z" clip-rule="evenodd" />
          </svg>
          <span class="text-[10px] uppercase tracking-wider font-semibold">{labels.locked}</span>
        </span>
      )}
    </header>

    {/* Teams — logos + names + vs divider */}
    {homeTeamProp && awayTeamProp && (
      <div class="teams-row grid grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-4">
        <div class="flex flex-col items-center text-center gap-2">
          <TeamLogo team={homeTeamProp} size="md" />
          <p class="text-xs font-semibold text-white-pure leading-tight line-clamp-2">{homeTeamProp.name}</p>
        </div>
        <span class="text-[10px] uppercase tracking-[0.15em] font-semibold text-white-faded">vs</span>
        <div class="flex flex-col items-center text-center gap-2">
          <TeamLogo team={awayTeamProp} size="md" />
          <p class="text-xs font-semibold text-white-pure leading-tight line-clamp-2">{awayTeamProp.name}</p>
        </div>
      </div>
    )}

    {/* Kickoff — server-rendered absolute time. When kickoffIso is
        present, the global kickoff-countdown script swaps the text
        to "Kickoff in 2h 34m" once we're within 24h of kickoff. */}
    {kickoff && (
      <p class="kickoff-info flex items-center justify-center gap-1.5 px-4 py-1.5 text-[11px] font-mono text-white-muted">
        <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .2.08.39.22.53l3 3a.75.75 0 101.06-1.06L10.75 9.69V5z" clip-rule="evenodd" />
        </svg>
        <time
          datetime={kickoffIso}
          data-kickoff-iso={kickoffIso}
          data-kickoff-locale={locale}
        >{kickoff}</time>
      </p>
    )}

    {/* Prediction body */}
    {(variant === "free" || variant === "locked") && (
      <div class={`prediction-body px-4 py-3 ${variant === "locked" ? "blur-[6px] select-none pointer-events-none" : ""}`}>
        {prediction && (
          <p class="text-base font-bold text-pitch-green-400">{prediction}</p>
        )}
        {market && (
          <p class="mt-0.5 text-[10px] uppercase tracking-wider font-semibold text-white-faded">
            {market}
          </p>
        )}
        {typeof confidence === "number" && (
          <div class="mt-3">
            <div class="confidence-bar relative h-1.5 rounded-full bg-deep-navy-900 overflow-hidden">
              <div
                class="confidence-fill h-full rounded-full bg-pitch-green-500"
                style={`--target-width: ${confidenceWidth}; width: ${confidenceWidth};`}
              ></div>
            </div>
            <div class="mt-1.5 flex items-center justify-between text-[11px]">
              <span class="text-white-muted">{labels.confidence}</span>
              <span class="font-mono font-semibold text-white-pure">{confidence}%</span>
            </div>
          </div>
        )}
      </div>
    )}

    {/* Fixture variant — no prediction */}
    {variant === "fixture" && (
      <p class="px-4 py-4 text-center text-sm font-medium text-white-muted">
        {labels.subscribeToView}
      </p>
    )}

    {/* Locked overlay */}
    {variant === "locked" && (
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-t from-deep-navy-900/95 via-deep-navy-900/80 to-deep-navy-900/30 p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-pitch-green-500/15">
          <svg class="h-5 w-5 text-pitch-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v3H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zm2 7V5a2 2 0 10-4 0v3h4z" clip-rule="evenodd" />
          </svg>
        </span>
        <p class="text-sm font-semibold text-white-pure">{labels.unlock}</p>
        <a
          href={pricingHref}
          class="inline-flex items-center justify-center h-9 px-4 rounded-md text-xs font-bold
                 bg-pitch-green-500 text-deep-navy-950 hover:bg-pitch-green-400
                 transition-colors duration-150
                 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
                 focus-visible:ring-offset-deep-navy-900"
        >
          {labels.viewPricing}
        </a>
      </div>
    )}

    {/* Whole-card link disabled until app.betsplug.com/predictions/{slug}
        match-detail pages exist. Re-enable by passing a real matchUrl
        once those routes ship — until then the click would 404. */}
  </article>
)}

<style>
  /* Club-colour accent on the left edge — strong visual tie to the
     home team without overpowering the surface palette. */
  .prediction-card {
    border-left: 3px solid var(--accent-color, var(--color-charcoal-300));
  }

  /* Top bar separator + kickoff separator give the card a stronger
     internal rhythm without adding extra DOM nodes. */
  .card-top {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.15);
  }
  .kickoff-info {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.10);
  }

  /* Confidence fill animates from 0 → target on first paint so the
     value always feels live, not pre-rendered. */
  .confidence-fill {
    transform-origin: left center;
    animation: confidenceGrow 800ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes confidenceGrow {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .confidence-fill { animation: none; }
  }
</style>

<script>
  // Kickoff countdown enhancement — swaps server-rendered absolute
  // time (e.g. "Sat 14:30") for a football-style countdown when the
  // match is within 24h of kickoff. Re-evaluates every 60s.
  // Original text is preserved in data-original so the swap is
  // reversible if the page survives past the 24h window.
  (function setupKickoffCountdowns() {
    type Locale = "en" | "nl" | "de" | "fr" | "es" | "it" | "sw";
    const STR: Record<Locale, { kickoffIn: string; d: string; h: string; m: string; inProgress: string }> = {
      en: { kickoffIn: "Kickoff in", d: "d", h: "h", m: "m", inProgress: "In progress" },
      nl: { kickoffIn: "Aftrap over", d: "d", h: "u", m: "m", inProgress: "Bezig" },
      de: { kickoffIn: "Anstoß in", d: "T", h: "Std", m: "Min", inProgress: "Läuft" },
      fr: { kickoffIn: "Coup d'envoi dans", d: "j", h: "h", m: "min", inProgress: "En cours" },
      es: { kickoffIn: "Saque inicial en", d: "d", h: "h", m: "min", inProgress: "En curso" },
      it: { kickoffIn: "Calcio d'inizio tra", d: "g", h: "h", m: "min", inProgress: "In corso" },
      sw: { kickoffIn: "Mechi inaanza baada ya", d: "siku", h: "saa", m: "dak", inProgress: "Inaendelea" },
    };

    function isLocale(v: string | null): v is Locale {
      return !!v && v in STR;
    }

    function buildLabel(iso: string, locale: Locale): string | null {
      const ts = new Date(iso).getTime();
      if (Number.isNaN(ts)) return null;

      const diffMs = ts - Date.now();
      const t = STR[locale];
      if (diffMs <= 0) return t.inProgress;

      // Only swap to countdown for matches within 24h. Above that,
      // the absolute time ("Sat 14:30") reads more naturally.
      if (diffMs > 24 * 60 * 60 * 1000) return null;

      const totalMin = Math.floor(diffMs / 60_000);
      const hours = Math.floor(totalMin / 60);
      const mins = totalMin % 60;

      if (hours >= 1) return `${t.kickoffIn} ${hours}${t.h} ${mins}${t.m}`;
      return `${t.kickoffIn} ${mins}${t.m}`;
    }

    function refresh() {
      const targets = document.querySelectorAll<HTMLElement>("[data-kickoff-iso]");
      targets.forEach((el) => {
        const iso = el.dataset.kickoffIso;
        const localeAttr = el.dataset.kickoffLocale ?? null;
        if (!iso || !isLocale(localeAttr)) return;

        if (!el.dataset.originalText) {
          el.dataset.originalText = el.textContent ?? "";
        }
        const label = buildLabel(iso, localeAttr);
        el.textContent = label ?? el.dataset.originalText;
      });
    }

    refresh();
    setInterval(refresh, 60_000);
  })();
</script>
