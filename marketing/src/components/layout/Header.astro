---
/**
 * Marketing Header — sticky top, deep-navy + backdrop-blur, with
 * primary nav, locale switcher, login link, and primary CTA. See
 * docs/specs/04-design-system.md → "NAVIGATION HEADER".
 *
 * Nav items + labels live in `src/config/navigation.ts` so the
 * Header, MobileDrawer, and Footer share one source of truth.
 *
 * Mobile: clicking the hamburger toggles `MobileDrawer` via
 * `data-mobile-menu-trigger`. A `<noscript>` fallback exposes a
 * details/summary sheet so the menu still works without JS (and
 * for crawlers that ignore JS).
 */
import {
  defaultLocale,
  getAllLocaleVersions,
  getLocalizedPath,
  isLocale,
  type Locale,
} from "@/lib/i18n";
import LocaleSwitcher from "@/components/ui/LocaleSwitcher.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import {
  headerNavItems,
  headerActions,
  navLabels,
} from "@/config/navigation";

interface Props {
  /** Override the locale detected from Astro.locals. */
  locale?: Locale;
  /** Canonical (EN) path of the current page, e.g. "/predictions". */
  canonicalPath?: string;
}

const localsLocale = (Astro.locals as { locale?: unknown })?.locale;
const locale: Locale =
  Astro.props.locale ?? (isLocale(localsLocale) ? localsLocale : defaultLocale);

const canonicalPath = Astro.props.canonicalPath ?? "/";
const localeVersions = getAllLocaleVersions(canonicalPath);
const t = navLabels[locale];

const navItems = headerNavItems.map((item) => ({
  href: getLocalizedPath(item.href, locale),
  label: t[item.key],
}));

const homeHref = locale === defaultLocale ? "/" : `/${locale}/`;
---

<header
  class="sticky top-0 z-40 w-full border-b border-white-pure/10
         bg-deep-navy-900/80 backdrop-blur-md
         supports-[backdrop-filter]:bg-deep-navy-900/70"
>
  <div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <!-- Brand ─────────────────────────────────────────────── -->
    <a
      href={homeHref}
      class="inline-flex shrink-0 items-center gap-2
             focus-visible:outline-none focus-visible:ring-2
             focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
             focus-visible:ring-offset-deep-navy-900 rounded-md"
      aria-label="BetsPlug home"
    >
      <img
        src="/logo.webp"
        alt=""
        width="140"
        height="56"
        class="h-8 w-auto sm:h-9"
        loading="eager"
        fetchpriority="high"
      />
      <span class="sr-only">BetsPlug</span>
    </a>

    <!-- Desktop nav ─────────────────────────────────────────── -->
    <nav
      aria-label="Primary"
      class="hidden lg:flex items-center gap-1"
    >
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm font-medium text-white-soft
                 hover:text-white-pure rounded-md
                 transition-colors duration-150
                 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
                 focus-visible:ring-offset-deep-navy-900"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right cluster ───────────────────────────────────────── -->
    <div class="flex items-center gap-2">
      <LocaleSwitcher
        currentLocale={locale}
        versions={localeVersions}
        surface="dark"
        class="hidden lg:block"
      />

      <a
        href={headerActions.login.href}
        rel="noopener"
        class="hidden lg:inline-flex items-center h-11 px-3 text-sm
               font-medium text-white-soft hover:text-white-pure
               rounded-md transition-colors duration-150
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900"
      >
        {t.login}
      </a>

      <Button
        href={headerActions.cta.href}
        variant="primary"
        size="sm"
        surface="dark"
        external
        class="hidden lg:inline-flex"
      >
        {t.getFreePicks}
      </Button>

      <!-- Mobile menu trigger ─────────────────────────────── -->
      <button
        type="button"
        data-mobile-menu-trigger
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        class="lg:hidden inline-flex h-11 w-11 items-center justify-center
               rounded-md border border-white-pure/15 text-white-soft
               hover:text-white-pure hover:border-white-pure/30
               transition-colors
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900"
      >
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <!-- No-JS fallback ──────────────────────────────────────────
       <noscript> details/summary keeps the navigation reachable
       when the drawer's JS doesn't run. -->
  <noscript>
    <details class="lg:hidden border-t border-white-pure/10 bg-deep-navy-900">
      <summary
        class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-white-soft"
      >
        {t.product} ▾
      </summary>
      <nav aria-label="Mobile fallback" class="px-4 pb-4 space-y-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="block px-3 py-3 text-sm font-medium text-white-soft
                   hover:text-white-pure hover:bg-white-pure/5 rounded-md"
          >
            {item.label}
          </a>
        ))}
        <a
          href={headerActions.login.href}
          rel="noopener"
          class="block px-3 py-3 text-sm font-medium text-white-soft
                 hover:text-white-pure hover:bg-white-pure/5 rounded-md"
        >
          {t.login}
        </a>
        <a
          href={headerActions.cta.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block mt-2 px-3 py-3 text-sm font-semibold text-white-pure
                 text-center rounded-md
                 [background:var(--gradient-pitch)]
                 shadow-[var(--shadow-glow-pitch)]"
        >
          {t.getFreePicks}
        </a>
      </nav>
    </details>
  </noscript>
</header>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ""; }
</style>
