---
/**
 * MobileDrawer — slide-out navigation panel from the right edge.
 *
 * Pair component to `Header.astro`'s mobile menu trigger button
 * (matched via `data-mobile-menu-trigger` ↔ `aria-controls`).
 * Renders only on viewports below `lg` since the desktop header
 * has its own visible nav.
 *
 * Behaviour (script at bottom):
 *   - Trigger click   → open
 *   - Backdrop click  → close
 *   - X button click  → close
 *   - Escape key      → close
 *   - Tab focus stays trapped inside the panel while open
 *   - <body> scroll locked while open
 *   - Last-focused element restored on close
 *   - prefers-reduced-motion disables the slide/fade transitions
 *
 * Accessibility:
 *   - role="dialog" + aria-modal="true"
 *   - aria-labelledby points to a sr-only h2
 *   - aria-hidden flips with state for screen-reader inertness
 *   - Touch targets ≥44px for every link/button (drawer-link min-h)
 */
import {
  defaultLocale,
  getAllLocaleVersions,
  getLocalizedPath,
  isLocale,
  type Locale,
} from "@/lib/i18n";
import {
  mobileNavGroups,
  headerActions,
  navLabels,
} from "@/config/navigation";
import LocaleSwitcher from "@/components/ui/LocaleSwitcher.astro";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  locale?: Locale;
  canonicalPath?: string;
}

const localsLocale = (Astro.locals as { locale?: unknown })?.locale;
const locale: Locale =
  Astro.props.locale ?? (isLocale(localsLocale) ? localsLocale : defaultLocale);

const canonicalPath = Astro.props.canonicalPath ?? "/";
const localeVersions = getAllLocaleVersions(canonicalPath);
const t = navLabels[locale];

const homeHref = locale === defaultLocale ? "/" : `/${locale}/`;

// Resolve groups to localized hrefs + labels once per render.
const groups = mobileNavGroups.map((group) => ({
  label: t[group.labelKey],
  items: group.items.map((item) => ({
    href: getLocalizedPath(item.href, locale),
    label: t[item.key],
  })),
}));
---

<div
  id="mobile-drawer"
  class="mobile-drawer fixed inset-0 z-50 lg:hidden invisible pointer-events-none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobile-drawer-title"
  aria-hidden="true"
  data-state="closed"
>
  <!-- Backdrop ─────────────────────────────────────────── -->
  <div
    class="drawer-backdrop absolute inset-0 bg-deep-navy-950/70 opacity-0
           transition-opacity duration-250 ease-out backdrop-blur-sm"
    data-drawer-backdrop
    aria-hidden="true"
  ></div>

  <!-- Panel ────────────────────────────────────────────── -->
  <aside
    class="drawer-panel absolute top-0 right-0 bottom-0 flex flex-col
           w-[min(360px,90vw)] bg-deep-navy-900
           border-l border-white-pure/10 shadow-2xl
           overflow-y-auto"
    aria-labelledby="mobile-drawer-title"
  >
    <!-- Header: logo + close ─────────────────────────── -->
    <div class="flex items-center justify-between px-5 py-4
                border-b border-white-pure/10 shrink-0">
      <a
        href={homeHref}
        class="inline-flex items-center
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900 rounded-md"
        aria-label="BetsPlug home"
      >
        <img
          src="/logo.webp"
          alt=""
          width="140"
          height="56"
          class="h-8 w-auto"
        />
        <span class="sr-only">BetsPlug</span>
      </a>

      <button
        type="button"
        data-drawer-close
        aria-label="Close menu"
        class="inline-flex h-11 w-11 items-center justify-center
               rounded-md text-white-soft hover:text-white-pure
               hover:bg-white-pure/5 transition-colors
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900"
      >
        <Icon name="x" size={22} />
      </button>
    </div>

    <h2 id="mobile-drawer-title" class="sr-only">Main navigation</h2>

    <!-- Navigation groups ────────────────────────────── -->
    <nav
      aria-label="Mobile navigation"
      class="flex-1 px-5 py-6 space-y-7"
    >
      {groups.map((group) => (
        <div>
          <h3
            class="text-[11px] font-semibold uppercase tracking-[0.08em]
                   text-white-faded mb-2 px-2"
          >
            {group.label}
          </h3>
          <ul class="space-y-0.5" role="list">
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="drawer-link flex items-center justify-between
                         min-h-[44px] px-3 py-2.5 rounded-md
                         text-base font-medium text-white-soft
                         hover:text-white-pure hover:bg-white-pure/5
                         transition-colors duration-150
                         focus-visible:outline-none focus-visible:ring-2
                         focus-visible:ring-pitch-green-400
                         focus-visible:ring-offset-2
                         focus-visible:ring-offset-deep-navy-900"
                >
                  <span>{item.label}</span>
                  <Icon
                    name="chevron-right"
                    size={16}
                    class="text-white-faded"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Locale switcher -->
      <div>
        <h3
          class="text-[11px] font-semibold uppercase tracking-[0.08em]
                 text-white-faded mb-2 px-2"
        >
          {t.language}
        </h3>
        <div class="px-2">
          <LocaleSwitcher
            currentLocale={locale}
            versions={localeVersions}
            surface="dark"
            mode="inline"
          />
        </div>
      </div>
    </nav>

    <!-- Footer: login + CTA ─────────────────────────── -->
    <div
      class="px-5 py-5 border-t border-white-pure/10 shrink-0
             space-y-3
             [background:linear-gradient(180deg,transparent,rgba(0,210,106,0.05))]"
    >
      <a
        href={headerActions.login.href}
        rel="noopener"
        class="flex items-center justify-center min-h-[44px] px-4 py-2.5
               rounded-md border border-white-pure/15 text-sm font-medium
               text-white-soft hover:text-white-pure hover:border-white-pure/30
               transition-colors
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900"
      >
        {t.login}
      </a>

      <a
        href={headerActions.cta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-1.5 min-h-[48px] px-4 py-3
               rounded-md text-base font-semibold text-white-pure
               [background:var(--gradient-pitch)]
               shadow-[var(--shadow-glow-pitch)]
               transition-transform duration-150
               hover:[filter:brightness(1.05)]
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-pitch-green-300
               focus-visible:ring-offset-2
               focus-visible:ring-offset-deep-navy-900"
      >
        {t.getFreePicks}
        <Icon name="chevron-right" size={18} />
      </a>
    </div>
  </aside>
</div>

<style>
  .drawer-panel {
    translate: 100% 0;
    transition: translate 300ms ease-out;
  }

  .mobile-drawer[data-state="open"] {
    visibility: visible;
    pointer-events: auto;
  }
  .mobile-drawer[data-state="open"] .drawer-backdrop {
    opacity: 1;
  }
  .mobile-drawer[data-state="open"] .drawer-panel {
    translate: 0 0;
  }

  /* Body lock helper — set by the script. */
  :global(body.drawer-open) {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .drawer-backdrop,
    .drawer-panel {
      transition: none !important;
    }
  }
</style>

<script>
  (() => {
    const drawer = document.getElementById("mobile-drawer");
    if (!drawer) return;

    const triggers = document.querySelectorAll<HTMLElement>(
      "[data-mobile-menu-trigger]",
    );
    const closeButtons = drawer.querySelectorAll<HTMLElement>(
      "[data-drawer-close]",
    );
    const backdrop = drawer.querySelector<HTMLElement>(
      "[data-drawer-backdrop]",
    );
    const focusableSelector =
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

    let lastFocused: HTMLElement | null = null;

    function setExpanded(open: boolean): void {
      triggers.forEach((trigger) => {
        trigger.setAttribute("aria-expanded", open ? "true" : "false");
      });
    }

    function open(): void {
      if (drawer!.dataset.state === "open") return;
      lastFocused = (document.activeElement as HTMLElement) ?? null;
      drawer!.dataset.state = "open";
      drawer!.setAttribute("aria-hidden", "false");
      document.body.classList.add("drawer-open");
      setExpanded(true);

      // Focus the close button after the panel is visible.
      window.requestAnimationFrame(() => {
        const closeBtn = drawer!.querySelector<HTMLElement>(
          "[data-drawer-close]",
        );
        closeBtn?.focus();
      });
    }

    function close(): void {
      if (drawer!.dataset.state === "closed") return;
      drawer!.dataset.state = "closed";
      drawer!.setAttribute("aria-hidden", "true");
      document.body.classList.remove("drawer-open");
      setExpanded(false);

      if (lastFocused && typeof lastFocused.focus === "function") {
        lastFocused.focus();
      }
      lastFocused = null;
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", open);
    });
    closeButtons.forEach((btn) => {
      btn.addEventListener("click", close);
    });
    backdrop?.addEventListener("click", close);

    document.addEventListener("keydown", (e) => {
      if (drawer.dataset.state !== "open") return;

      if (e.key === "Escape") {
        e.preventDefault();
        close();
        return;
      }

      // Focus trap.
      if (e.key === "Tab") {
        const focusables = Array.from(
          drawer.querySelectorAll<HTMLElement>(focusableSelector),
        ).filter(
          (el) => !el.hasAttribute("disabled") && el.offsetParent !== null,
        );
        if (focusables.length === 0) return;

        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;

        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Close drawer on link click (after small delay so the visual
    // feedback is visible before the page change).
    drawer
      .querySelectorAll<HTMLAnchorElement>("a[href]")
      .forEach((link) => {
        link.addEventListener("click", () => {
          window.setTimeout(close, 100);
        });
      });
  })();
</script>
