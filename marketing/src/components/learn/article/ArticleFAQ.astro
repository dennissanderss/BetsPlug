---
import type { ArticleContent } from "@/content/articles/types";
interface Props { content: ArticleContent["faq"] }
const { content } = Astro.props;
---

<section class="mt-12">
  <h2 class="text-2xl sm:text-3xl font-bold leading-tight tracking-tight text-charcoal-900">{content.h2}</h2>

  <div class="mt-6 divide-y divide-stadium-white-200 rounded-2xl border border-stadium-white-200 bg-white shadow-[var(--shadow-sm)]">
    {content.questions.map((item) => (
      <details class="group" name="article-faq">
        <summary class="flex items-center justify-between gap-4 cursor-pointer px-6 py-4 list-none text-left">
          <span class="text-base font-semibold text-charcoal-900">{item.q}</span>
          <svg class="h-5 w-5 shrink-0 text-charcoal-500 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="px-6 pb-4 text-sm leading-relaxed text-charcoal-700">{item.a}</div>
      </details>
    ))}
  </div>
</section>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ""; }
</style>
