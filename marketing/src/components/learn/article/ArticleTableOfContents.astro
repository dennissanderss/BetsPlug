---
/**
 * ArticleTableOfContents — sticky sidebar TOC with scroll-spy.
 */
import type { ArticleContent } from "@/content/articles/types";

interface Props {
  label: string;
  sections: ArticleContent["sections"];
}
const { label, sections } = Astro.props;
---

<aside class="article-toc">
  <details class="lg:hidden mb-6 rounded-xl border border-stadium-white-200 bg-white p-4">
    <summary class="cursor-pointer flex items-center justify-between text-sm font-semibold text-charcoal-900 list-none">
      <span>{label}</span>
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </summary>
    <ol class="mt-3 space-y-1 text-sm">
      {sections.map((s, i) => (
        <li>
          <a href={`#${s.id}`} class="block py-1.5 text-charcoal-700 hover:text-pitch-green-600 transition-colors">
            <span class="font-mono text-xs text-charcoal-500 mr-2">{String(i + 1).padStart(2, "0")}</span>
            {s.h2}
          </a>
        </li>
      ))}
    </ol>
  </details>

  <nav class="hidden lg:block sticky top-24" aria-label="Table of contents">
    <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500 mb-3">{label}</p>
    <ol class="space-y-1 text-sm border-l border-stadium-white-200">
      {sections.map((s, i) => (
        <li>
          <a
            href={`#${s.id}`}
            data-toc-link
            data-target={s.id}
            class="block px-4 py-2 text-charcoal-700 hover:text-pitch-green-600 hover:border-pitch-green-500 transition-colors -ml-px border-l border-transparent"
          >
            <span class="font-mono text-xs text-charcoal-500 mr-2">{String(i + 1).padStart(2, "0")}</span>
            {s.h2}
          </a>
        </li>
      ))}
    </ol>
  </nav>
</aside>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ""; }
  [data-toc-link][data-active="true"] {
    color: var(--color-pitch-green-600);
    border-color: var(--color-pitch-green-500);
    font-weight: 600;
  }
  html { scroll-padding-top: 80px; }
</style>

<script>
  (function () {
    const links = Array.from(document.querySelectorAll("[data-toc-link]")) as HTMLElement[];
    if (!links.length) return;
    const sections = links
      .map((l) => l.getAttribute("data-target"))
      .filter((t): t is string => Boolean(t))
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => Boolean(el));
    let active: string | null = null;
    function setActive(id: string | null) {
      if (id === active) return;
      active = id;
      for (const link of links) {
        if (link.getAttribute("data-target") === id) link.setAttribute("data-active", "true");
        else link.removeAttribute("data-active");
      }
    }
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => (a.target as HTMLElement).offsetTop - (b.target as HTMLElement).offsetTop);
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: "-80px 0px -60% 0px" },
    );
    for (const sec of sections) io.observe(sec);
  })();
</script>
