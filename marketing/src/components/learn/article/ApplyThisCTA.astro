---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { ArticleContent } from "@/content/articles/types";

interface Props {
  locale: Locale;
  content: ArticleContent["applyThis"];
}
const { locale, content } = Astro.props;
const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<Section surface="light" spacing="lg" ariaLabelledby="apply-this-h2">
  <Container size="md" class="text-center">
    <h2 id="apply-this-h2" class="text-2xl sm:text-3xl font-bold leading-tight tracking-tight text-charcoal-900">
      {content.h2}
    </h2>
    <p class="mt-4 text-base lg:text-lg leading-relaxed text-charcoal-700 max-w-2xl mx-auto">{content.body}</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <Button href={ctaPrimaryHref} variant="primary" size="md" surface="light">{content.ctaPrimary.label}</Button>
      <Button href={ctaSecondaryHref} variant="secondary" size="md" surface="light">{content.ctaSecondary.label}</Button>
    </div>
  </Container>
</Section>
