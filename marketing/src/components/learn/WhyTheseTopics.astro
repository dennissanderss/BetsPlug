---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import type { LearnHubContent } from "@/content/pages/learn/types";

interface Props { content: LearnHubContent["whyTopics"] }
const { content } = Astro.props;
---

<Section surface="dark-glow" spacing="lg" ariaLabelledby="why-topics-h2">
  <Container size="md">
    <h2 id="why-topics-h2" class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure">
      {content.h2}
    </h2>
    <div class="mt-6 space-y-5 text-base lg:text-[17px] leading-relaxed text-white-soft">
      {content.paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </Container>
</Section>
