---
/**
 * ArticleCard — central learn-article card component.
 * Used on /learn hub (3-column grid) and per-article RelatedArticles
 * section (3 cards horizontally).
 *
 * Resolves canonical article slug to localized URL + folder via
 * slug-mappings. Difficulty badge + reading time + excerpt + chevron.
 */
import { getLocalizedPath, getLocalizedSlug, type Locale } from "@/lib/i18n";
import type { Difficulty } from "@/content/pages/learn/types";

interface Props {
  locale: Locale;
  /** Canonical (English) article slug — e.g. "expected-goals-explained". */
  slug: string;
  title: string;
  excerpt: string;
  readingTime: string;
  difficulty: Difficulty;
  /** Localized "Read article" label. */
  readMoreLabel: string;
  /** Localized difficulty label per Difficulty value. */
  difficultyLabels: Record<Difficulty, string>;
}

const { locale, slug, title, excerpt, readingTime, difficulty, readMoreLabel, difficultyLabels } = Astro.props;

// Build localized URL: /learn/{slug} on EN, /{locale}/{learnFolder}/{localizedSlug} on others.
const learnFolder = getLocalizedPath("learn", locale).replace(/^\//, "");
const localizedSlug = getLocalizedSlug(slug, locale);
const href = locale === "en" ? `/${learnFolder}/${slug}` : `/${learnFolder}/${localizedSlug}`;

const difficultyClasses: Record<Difficulty, string> = {
  Beginner:     "bg-pitch-green-100 text-pitch-green-900",
  Intermediate: "bg-plasma-blue-300 text-deep-navy-900",
  Advanced:     "bg-charcoal-300 text-charcoal-900",
};
---

<a
  href={href}
  class="group block h-full rounded-xl border border-stadium-white-200 bg-white p-6
         transition-all duration-200 hover:border-pitch-green-500/40
         hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5
         focus-visible:outline-none focus-visible:ring-2
         focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2
         focus-visible:ring-offset-stadium-white-50"
>
  <!-- Top: difficulty + reading time -->
  <div class="flex items-center justify-between">
    <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-bold uppercase tracking-wider ${difficultyClasses[difficulty]}`}>
      {difficultyLabels[difficulty]}
    </span>
    <span class="font-mono text-xs text-charcoal-500">{readingTime}</span>
  </div>

  <!-- Middle: title -->
  <h3 class="mt-4 text-lg font-bold leading-snug text-charcoal-900 group-hover:text-pitch-green-600 transition-colors">
    {title}
  </h3>

  <!-- Body: excerpt -->
  <p class="mt-3 text-sm leading-relaxed text-charcoal-700 line-clamp-3">
    {excerpt}
  </p>

  <!-- Bottom: read more link -->
  <p class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-pitch-green-600">
    {readMoreLabel}
    <svg class="h-3 w-3 transition-transform duration-150 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </p>
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
