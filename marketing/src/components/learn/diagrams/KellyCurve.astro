---
/**
 * KellyCurve — bankroll growth over many bets, comparing flat staking
 * vs Full Kelly vs Half Kelly vs Over-Kelly (which goes broke).
 * Pure SVG line chart.
 */
interface Props {
  caption: string;
  surface?: "light" | "dark";
}
const { caption, surface = "light" } = Astro.props;

const fg     = surface === "dark" ? "rgb(232,234,239)" : "rgb(15,20,25)";
const muted  = surface === "dark" ? "rgb(155,163,181)" : "rgb(90,100,120)";
const accent = "#00d26a";
const blue   = "#3b82f6";
const danger = "#dc2626";

const W = 720, H = 360;
const padL = 70, padR = 30, padT = 40, padB = 60;
const plotW = W - padL - padR;
const plotH = H - padT - padB;

// Simulate a 100-bet sequence with 55% win rate, decimal odds 2.0.
// Returns log10 of bankroll multiplier per bet step.
const N = 100;
const winRate = 0.55;
const odds = 2.0;
const b = odds - 1;
const p = winRate;
const q = 1 - p;
const fullKelly = (b * p - q) / b; // 0.10

// Deterministic outcomes — alternating pattern producing 55 wins / 45 losses.
const outcomes: number[] = [];
for (let i = 0; i < N; i++) outcomes.push((i * 9) % 20 < 11 ? 1 : 0);

function sim(fraction: number): number[] {
  let bankroll = 1;
  const series: number[] = [bankroll];
  for (const r of outcomes) {
    const stake = bankroll * fraction;
    if (r === 1) bankroll = bankroll - stake + stake * odds;
    else bankroll = bankroll - stake;
    if (bankroll <= 0) bankroll = 0.001;
    series.push(bankroll);
  }
  return series;
}

const flat       = sim(0.02);
const halfKelly  = sim(fullKelly / 2);
const fullKellyS = sim(fullKelly);
const overKelly  = sim(fullKelly * 2.5);

const allValues = [...flat, ...halfKelly, ...fullKellyS, ...overKelly];
const yMin = 0;
const yMax = Math.max(...allValues, 5);

const xScale = (i: number) => padL + (i / N) * plotW;
const yScale = (v: number) => padT + plotH - ((v - yMin) / (yMax - yMin)) * plotH;

function pathFor(series: number[]): string {
  return series.map((v, i) => `${i === 0 ? "M" : "L"} ${xScale(i)} ${yScale(v)}`).join(" ");
}
---

<figure class="my-8">
  <div class={`rounded-2xl border ${surface === "dark" ? "border-deep-navy-600 bg-deep-navy-800/60" : "border-stadium-white-200 bg-white"} p-6 lg:p-8`}>
    <svg viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <!-- Y axis -->
      <line x1={padL} y1={padT} x2={padL} y2={padT + plotH} stroke={muted} stroke-width="1"/>
      {[0, 1, 2, 3, 4, 5].map((v) => (
        <g>
          <line x1={padL} y1={yScale(v)} x2={padL + plotW} y2={yScale(v)} stroke={muted} stroke-opacity="0.15"/>
          <text x={padL - 8} y={yScale(v) + 4} font-family="Geist Mono, ui-monospace, monospace" font-size="10" text-anchor="end" fill={muted}>{v}×</text>
        </g>
      ))}
      <text x={20} y={padT + plotH / 2} font-family="Inter, sans-serif" font-size="11" font-weight="600" fill={muted} transform={`rotate(-90 20 ${padT + plotH / 2})`}>Bankroll multiple</text>

      <!-- X axis -->
      <line x1={padL} y1={padT + plotH} x2={padL + plotW} y2={padT + plotH} stroke={muted} stroke-width="1"/>
      {[0, 25, 50, 75, 100].map((i) => (
        <text x={xScale(i)} y={padT + plotH + 18} font-family="Geist Mono, ui-monospace, monospace" font-size="10" text-anchor="middle" fill={muted}>{i}</text>
      ))}
      <text x={padL + plotW / 2} y={padT + plotH + 42} font-family="Inter, sans-serif" font-size="11" font-weight="600" text-anchor="middle" fill={muted}>Bets placed</text>

      <!-- Curves -->
      <path d={pathFor(overKelly)}  fill="none" stroke={danger} stroke-width="2" stroke-dasharray="6 4" />
      <path d={pathFor(flat)}       fill="none" stroke={muted}  stroke-width="2" />
      <path d={pathFor(halfKelly)}  fill="none" stroke={blue}   stroke-width="2.5" />
      <path d={pathFor(fullKellyS)} fill="none" stroke={accent} stroke-width="2.5" />

      <!-- Legend -->
      <g>
        <rect x={padL + plotW - 220} y={padT + 8} width="210" height="80" fill={surface === "dark" ? "rgba(10,14,31,0.7)" : "rgba(255,255,255,0.9)"} stroke={muted} stroke-opacity="0.3" rx="4"/>
        <line x1={padL + plotW - 208} y1={padT + 24} x2={padL + plotW - 188} y2={padT + 24} stroke={accent} stroke-width="2.5"/>
        <text x={padL + plotW - 180} y={padT + 27} font-family="Inter, sans-serif" font-size="11" fill={fg}>Full Kelly (10%)</text>
        <line x1={padL + plotW - 208} y1={padT + 42} x2={padL + plotW - 188} y2={padT + 42} stroke={blue} stroke-width="2.5"/>
        <text x={padL + plotW - 180} y={padT + 45} font-family="Inter, sans-serif" font-size="11" fill={fg}>Half Kelly (5%)</text>
        <line x1={padL + plotW - 208} y1={padT + 60} x2={padL + plotW - 188} y2={padT + 60} stroke={muted} stroke-width="2"/>
        <text x={padL + plotW - 180} y={padT + 63} font-family="Inter, sans-serif" font-size="11" fill={fg}>Flat 2%</text>
        <line x1={padL + plotW - 208} y1={padT + 78} x2={padL + plotW - 188} y2={padT + 78} stroke={danger} stroke-width="2" stroke-dasharray="6 4"/>
        <text x={padL + plotW - 180} y={padT + 81} font-family="Inter, sans-serif" font-size="11" fill={fg}>Over-Kelly (25%)</text>
      </g>
    </svg>
  </div>
  <figcaption class={`mt-3 text-center text-sm ${surface === "dark" ? "text-white-muted" : "text-charcoal-500"}`}>
    {caption}
  </figcaption>
</figure>
