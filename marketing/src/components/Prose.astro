---
// Wrapper that applies sensible typography defaults to long-form
// page content (terms / privacy / cookies / etc.) without pulling
// the full @tailwindcss/typography plugin. NOCTURNE-aligned.
---

<div
  class="prose-noct mx-auto max-w-3xl px-4 pb-12 sm:px-6 lg:px-8 [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-white [&_h3]:mt-6 [&_h3]:mb-3 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-[var(--color-accent-green-bright)] [&_p]:mb-4 [&_p]:text-sm [&_p]:leading-relaxed [&_p]:text-[var(--color-text-muted)] [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-5 [&_ul]:text-sm [&_ul]:text-[var(--color-text-muted)] [&_li]:leading-relaxed [&_a]:text-[var(--color-accent-green-bright)] [&_a]:underline [&_a]:decoration-[var(--color-accent-green-bright)]/40 [&_a]:underline-offset-2 [&_strong]:font-semibold [&_strong]:text-white"
>
  <slot />
</div>
