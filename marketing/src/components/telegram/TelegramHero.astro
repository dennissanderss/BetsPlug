---
import Container from "@/components/ui/Container.astro";
import type { TelegramContent } from "@/content/pages/telegram/types";

interface Props { content: TelegramContent["hero"] }
const { content } = Astro.props;
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[50vh] py-16 md:py-24" aria-labelledby="telegram-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-dark);"></div>
  <!-- Telegram-blue accent glow -->
  <div aria-hidden="true" class="pointer-events-none absolute -top-20 right-[-10%] h-[480px] w-[480px] rounded-full opacity-30 blur-[100px]" style="background: radial-gradient(circle, rgba(0,136,204,0.40) 0%, rgba(0,136,204,0) 70%);"></div>

  <Container size="md" class="relative text-center">
    <!-- Telegram airplane icon -->
    <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-[#0088CC]/15 text-[#1A9BD5] mb-6" aria-hidden="true">
      <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </span>

    <h1 id="telegram-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold leading-[1.05] tracking-tight text-white-pure">
      {content.h1}
    </h1>
    <p class="mt-6 text-lg sm:text-xl leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>

    <!-- Telegram-blue CTA — overrides brand pitch-green for context recognition -->
    <a
      href={content.telegramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-3 h-14 px-8 rounded-md
             bg-[#0088CC] hover:bg-[#1A9BD5] text-white font-bold text-base
             shadow-[0_4px_16px_rgba(0,136,204,0.4)]
             transition-all duration-150 hover:scale-[1.02]
             focus-visible:outline-none focus-visible:ring-2
             focus-visible:ring-[#0088CC] focus-visible:ring-offset-2
             focus-visible:ring-offset-deep-navy-900"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      {content.ctaLabel}
    </a>

    <ul class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white-soft">
      {content.trustStrip.map((item) => (
        <li class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 text-pitch-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {item}
        </li>
      ))}
    </ul>
  </Container>
</section>
