---
const links = [
  { href: "/match-predictions", label: "Predictions" },
  { href: "/track-record", label: "Track record" },
  { href: "/pricing", label: "Pricing" },
  { href: "/engine", label: "Engine" },
  { href: "/learn", label: "Learn" },
];
---

<header class="relative z-10 border-b border-white/[0.06]">
  <div
    class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
  >
    <a
      href="/"
      class="inline-flex items-center"
      aria-label="BetsPlug home"
    >
      <img
        src="/logo.webp"
        alt="BetsPlug"
        width="180"
        height="72"
        class="h-10 w-auto sm:h-12 drop-shadow-[0_0_18px_rgba(74,222,128,0.35)]"
      />
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-[var(--color-text-muted)] transition-colors hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a href="https://app.betsplug.com/login" class="btn-ghost text-xs"
        >Login</a
      >
      <a href="/pricing" class="btn-primary text-xs">Get started</a>
    </div>
  </div>
</header>
