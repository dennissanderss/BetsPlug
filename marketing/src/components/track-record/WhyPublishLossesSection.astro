---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  content: TrackRecordContent["whyPublishLosses"];
  totalEverPublished: number;
  daysOfTracking: number;
  lastAddedAt: string;
}
const { content, totalEverPublished, daysOfTracking, lastAddedAt } = Astro.props;
const lastAddedDisplay = new Date(lastAddedAt).toLocaleString("en-GB", { dateStyle: "medium", timeStyle: "short" });
---

<Section surface="dark" spacing="lg" ariaLabelledby="why-publish-losses-h2">
  <Container size="xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
      <div class="lg:col-span-7">
        <h2 id="why-publish-losses-h2" class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure">
          {content.h2}
        </h2>
        <div class="mt-6 space-y-5 text-base lg:text-[17px] leading-relaxed text-white-soft">
          {content.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <aside class="lg:col-span-5">
        <div class="rounded-2xl border border-deep-navy-600 bg-deep-navy-800/70 p-6 lg:p-8">
          <dl class="space-y-5 text-sm">
            <div>
              <dt class="text-[11px] font-medium uppercase tracking-wider text-white-muted">{content.panel.totalLabel}</dt>
              <dd class="mt-1 font-mono text-3xl font-bold text-pitch-green-400">{totalEverPublished.toLocaleString("en-GB")}</dd>
            </div>
            <div>
              <dt class="text-[11px] font-medium uppercase tracking-wider text-white-muted">{content.panel.daysLabel}</dt>
              <dd class="mt-1 font-mono text-3xl font-bold text-white-pure">{daysOfTracking}</dd>
            </div>
            <div>
              <dt class="text-[11px] font-medium uppercase tracking-wider text-white-muted">{content.panel.leaguesLabel}</dt>
              <dd class="mt-1 font-mono text-3xl font-bold text-white-pure">{content.panel.leaguesValue}</dd>
            </div>
            <div>
              <dt class="text-[11px] font-medium uppercase tracking-wider text-white-muted">{content.panel.lastAddedLabel}</dt>
              <dd class="mt-1 text-sm text-white-soft">{lastAddedDisplay}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </Container>
</Section>
