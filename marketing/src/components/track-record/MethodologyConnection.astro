---
/**
 * Section 5 — Bridge to /methodology.
 * Connects "track record" (proof) with "methodology" (mechanism)
 * so the visitor sees them as one story, not two pages.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  locale: Locale;
  content: TrackRecordContent["methodologyConnection"];
}
const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="dark-corner-accent" spacing="lg" ariaLabelledby="tr-method-h2">
  <Container size="md">
    <div class="text-center">
      <h2
        id="tr-method-h2"
        class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-white-pure"
        set:html={parseAccent(content.h2)}
      ></h2>

      <div class="mt-6 space-y-5 text-base lg:text-lg leading-relaxed text-white-soft">
        {content.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>

      <div class="mt-8 flex justify-center">
        <Button href={ctaHref} variant="secondary" size="lg" surface="dark">
          {content.cta.label}
        </Button>
      </div>
    </div>
  </Container>
</Section>
