---
/**
 * Track Record Hero — trust-building hero for /track-record.
 * Primary CTA pushes to /pricing (conversion).
 * Secondary CTA links to the app's full track record (external).
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import GlowOrb from "@/components/ui/GlowOrb.astro";
import StadiumLightArc from "@/components/ui/StadiumLightArc.astro";
import AccentGrid from "@/components/ui/AccentGrid.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  locale: Locale;
  content: TrackRecordContent["hero"];
}
const { locale, content } = Astro.props;
const ctaPrimaryHref   = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[40vh] py-16 md:py-20 isolate"
  aria-labelledby="track-record-hero-h1"
>
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-atmospheric);"></div>
  <StadiumLightArc position="top-center" intensity="medium" />
  <GlowOrb size="xl" color="pitch-green" position="top-right"   intensity="medium" blur={120} />
  <GlowOrb size="lg" color="pitch-green" position="bottom-left" intensity="low"    blur={100} />
  <AccentGrid variant="subtle" position="top-right" fade />

  <Container size="md" class="relative z-10 text-center">
    <h1
      id="track-record-hero-h1"
      class="text-3xl sm:text-4xl lg:text-5xl xl:text-[64px] font-bold leading-[1.0] tracking-tight text-white-pure"
      set:html={parseAccent(content.h1)}
    ></h1>

    <p class="mt-6 text-lg sm:text-xl leading-relaxed text-white-soft max-w-2xl mx-auto">
      {content.subheadline}
    </p>

    <ul class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3 text-sm">
      {content.trustStrip.map((item) => (
        <li>
          <USPItem
            icon={item.icon as IconName}
            text={item.text}
            size="sm"
            surface="dark"
          />
        </li>
      ))}
    </ul>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">
        {content.ctaPrimary.label}
      </Button>
      <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">
        {content.ctaSecondary.label}
      </Button>
    </div>
  </Container>
</section>
