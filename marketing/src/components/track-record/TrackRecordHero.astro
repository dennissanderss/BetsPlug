---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  locale: Locale;
  content: TrackRecordContent["hero"];
}
const { locale, content } = Astro.props;
const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[40vh] py-16 md:py-20" aria-labelledby="track-record-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-dark);"></div>
  <svg aria-hidden="true" class="absolute inset-0 h-full w-full opacity-[0.025] pointer-events-none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="tr-grid" width="80" height="80" patternUnits="userSpaceOnUse">
        <path d="M 80 0 L 0 0 0 80" fill="none" stroke="white" stroke-width="1" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#tr-grid)" />
  </svg>
  <div aria-hidden="true" class="pointer-events-none absolute -top-24 right-[-10%] h-[480px] w-[480px] rounded-full opacity-30 blur-[100px]" style="background: radial-gradient(circle, rgba(0,210,106,0.40) 0%, rgba(0,210,106,0) 70%);"></div>

  <Container size="md" class="relative text-center">
    <h1 id="track-record-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl xl:text-[64px] font-bold leading-[1.0] tracking-tight text-white-pure">
      {content.h1}
    </h1>
    <p class="mt-6 text-lg sm:text-xl leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>

    <ul class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white-soft">
      {content.trustStrip.map((item) => (
        <li class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 text-pitch-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {item}
        </li>
      ))}
    </ul>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">{content.ctaPrimary.label}</Button>
      <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">{content.ctaSecondary.label}</Button>
    </div>
  </Container>
</section>
