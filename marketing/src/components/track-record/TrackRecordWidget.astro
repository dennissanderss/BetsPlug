---
/**
 * TrackRecordWidget — calendar-style 90-day grid with one tile per
 * prediction, colored by result. Date-range selector + league filter.
 *
 * Server renders the initial 90-day view from the API. Range/league
 * switches are URL-param-driven (?range=30|90|all, ?league=...).
 *
 * Accessibility: ARIA grid role, color-not-only-indicator (icon +
 * tooltip text), keyboard-accessible buttons.
 */
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface TrackRecordEntry {
  id: string;
  date: string;
  homeTeam: string;
  awayTeam: string;
  league: string;
  prediction: string;
  market: string;
  confidence: number;
  result: "win" | "loss" | "void";
  lockedAt: string;
  matchUrl: string;
}

interface Summary {
  totalCount: number;
  wins: number;
  losses: number;
  voids: number;
  predictions: TrackRecordEntry[];
  rangeStart: string;
  rangeEnd: string;
}

interface Props {
  content: TrackRecordContent["widget"];
  summary: Summary | null;
  range: 30 | 90 | "all";
  league: string | null;
  topLeagues: string[];
  baseHref: string;
}

const { content, summary, range, league, topLeagues, baseHref } = Astro.props;

const filtered = summary
  ? summary.predictions.filter((p) => !league || p.league === league)
  : [];

const totalShown = filtered.length;
const winsShown   = filtered.filter((p) => p.result === "win").length;
const lossesShown = filtered.filter((p) => p.result === "loss").length;
const voidsShown  = filtered.filter((p) => p.result === "void").length;

const winPct  = totalShown ? Math.round((winsShown / totalShown) * 100) : 0;
const lossPct = totalShown ? Math.round((lossesShown / totalShown) * 100) : 0;

// Group by date for grid display.
const byDate = new Map<string, TrackRecordEntry[]>();
for (const p of filtered) {
  if (!byDate.has(p.date)) byDate.set(p.date, []);
  byDate.get(p.date)!.push(p);
}
const sortedDates = Array.from(byDate.keys()).sort();

const colorFor: Record<TrackRecordEntry["result"], string> = {
  win:  "bg-pitch-green-500",
  loss: "bg-danger",
  void: "bg-warning",
};
---

<div class="rounded-2xl border border-stadium-white-200 bg-white p-6 lg:p-8 shadow-[var(--shadow-sm)]">
  <!-- Range + league selectors -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="inline-flex items-center gap-1 rounded-full border border-stadium-white-200 bg-stadium-white-50 p-1" role="tablist" aria-label={content.rangeLabel}>
      {([30, 90, "all"] as const).map((r) => {
        const href = `${baseHref}?range=${r}${league ? `&league=${encodeURIComponent(league)}` : ""}`;
        const label = r === 30 ? content.range30 : r === 90 ? content.range90 : content.rangeAll;
        return (
          <a
            href={href}
            role="tab"
            aria-selected={r === range}
            class={[
              "inline-flex items-center justify-center h-8 px-3 rounded-full text-xs font-semibold transition-colors duration-150",
              "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white",
              r === range ? "bg-pitch-green-500 text-deep-navy-950" : "text-charcoal-700 hover:text-charcoal-900",
            ].join(" ")}
          >
            {label}
          </a>
        );
      })}
    </div>

    <form action={baseHref} method="get" class="inline-flex items-center gap-2 text-sm">
      <input type="hidden" name="range" value={String(range)} />
      <label for="league-filter" class="text-charcoal-700">{content.leagueLabel}:</label>
      <select
        id="league-filter"
        name="league"
        class="h-9 rounded-md border border-stadium-white-200 bg-white px-3 text-sm text-charcoal-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-400"
        onchange="this.form.submit()"
      >
        <option value="" selected={!league}>{content.leagueAll}</option>
        {topLeagues.map((l) => (
          <option value={l} selected={l === league}>{l}</option>
        ))}
      </select>
    </form>
  </div>

  <!-- Stats bar -->
  {summary === null ? (
    <div class="mt-6 rounded-xl bg-stadium-white-50 p-6 text-center" aria-busy="true" aria-live="polite">
      <p class="text-sm text-charcoal-500">{content.loadingLabel}</p>
    </div>
  ) : totalShown === 0 ? (
    <div class="mt-6 rounded-xl bg-stadium-white-50 p-6 text-center">
      <p class="text-sm text-charcoal-500">{content.errorLabel}</p>
    </div>
  ) : (
    <>
      <dl class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-lg border border-stadium-white-200 bg-stadium-white-50 p-4 text-center">
          <dt class="text-[11px] font-medium uppercase tracking-wider text-charcoal-500">{content.statsTotal}</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-charcoal-900">{totalShown}</dd>
        </div>
        <div class="rounded-lg border border-stadium-white-200 bg-pitch-green-500/5 p-4 text-center">
          <dt class="text-[11px] font-medium uppercase tracking-wider text-pitch-green-700">{content.statsWins}</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-pitch-green-700">{winsShown} <span class="text-base font-medium">({winPct}%)</span></dd>
        </div>
        <div class="rounded-lg border border-stadium-white-200 bg-danger/5 p-4 text-center">
          <dt class="text-[11px] font-medium uppercase tracking-wider text-danger">{content.statsLosses}</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-danger">{lossesShown} <span class="text-base font-medium">({lossPct}%)</span></dd>
        </div>
        <div class="rounded-lg border border-stadium-white-200 bg-warning/5 p-4 text-center">
          <dt class="text-[11px] font-medium uppercase tracking-wider text-warning">{content.statsVoids}</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-warning">{voidsShown}</dd>
        </div>
      </dl>

      <!-- 90-day calendar grid -->
      <div role="grid" aria-label="Track record calendar grid" class="mt-8 grid grid-cols-[repeat(auto-fill,minmax(80px,1fr))] gap-3">
        {sortedDates.map((date) => {
          const dayPredictions = byDate.get(date)!;
          const d = new Date(date);
          const dayLabel = d.getDate();
          const monthLabel = d.toLocaleString("en-GB", { month: "short" });
          return (
            <div role="row" class="rounded-lg border border-stadium-white-200 bg-stadium-white-50 p-2">
              <p class="text-[10px] font-medium uppercase tracking-wider text-charcoal-500 text-center">
                {monthLabel} {dayLabel}
              </p>
              <div class="mt-2 grid grid-cols-3 gap-1">
                {dayPredictions.map((p) => (
                  <a
                    role="gridcell"
                    href={p.matchUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={content.tooltipPattern
                      .replace("{result}", p.result)
                      .replace("{home}", p.homeTeam)
                      .replace("{away}", p.awayTeam)
                      .replace("{prediction}", p.prediction)
                      .replace("{date}", p.date)}
                    aria-label={`${p.result}: ${p.homeTeam} vs ${p.awayTeam}, ${p.prediction}, locked ${p.date}`}
                    class={`block aspect-square rounded ${colorFor[p.result]} hover:scale-110 transition-transform duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pitch-green-700 focus-visible:ring-offset-1`}
                  ></a>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Legend -->
      <ul class="mt-6 flex flex-wrap items-center gap-4 text-xs text-charcoal-700">
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-pitch-green-500" aria-hidden="true"></span>
          {content.legendWin}
        </li>
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-danger" aria-hidden="true"></span>
          {content.legendLoss}
        </li>
        <li class="inline-flex items-center gap-1.5">
          <span class="h-3 w-3 rounded bg-warning" aria-hidden="true"></span>
          {content.legendVoid}
        </li>
      </ul>

      <!-- Explanation -->
      <div class="mt-8 border-t border-stadium-white-200 pt-6">
        <h3 class="text-base font-bold text-charcoal-900">{content.explanationH3}</h3>
        <p class="mt-3 text-sm leading-relaxed text-charcoal-700">{content.explanationBody}</p>
      </div>
    </>
  )}
</div>
