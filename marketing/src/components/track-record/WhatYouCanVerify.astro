---
/**
 * Section 4 — "How predictions become permanent."
 *
 * Two-column: feature list explaining the lock mechanism + a
 * stylized mockup of a locked prediction record. CTA bridges to
 * /methodology so the reader can dig into the technical guarantees.
 *
 * The component is still called WhatYouCanVerify (and the JSON key
 * still `whatYouCanVerify`) so the content schema stays stable;
 * only the copy and the CTA target moved.
 */
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import USPItem from "@/components/ui/USPItem.astro";
import AppMockup from "@/components/track-record/AppMockup.astro";
import type { IconName } from "@/components/ui/icon-types";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  locale: Locale;
  content: TrackRecordContent["whatYouCanVerify"];
}
const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="light-grid" spacing="lg" ariaLabelledby="tr-verify-h2">
  <Container size="xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="order-2 lg:order-1">
        <h2
          id="tr-verify-h2"
          class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900"
          set:html={parseAccent(content.h2)}
        ></h2>
        <p class="mt-4 text-base lg:text-lg leading-relaxed text-charcoal-700">
          {content.subH2}
        </p>

        <ul class="mt-8 space-y-3">
          {content.features.map((f) => (
            <li>
              <USPItem
                icon={f.icon as IconName}
                text={f.text}
                size="md"
                surface="light"
              />
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={ctaHref} variant="primary" size="lg" surface="light">
            {content.cta.label}
          </Button>
        </div>
        <p class="mt-3 text-sm text-charcoal-700">{content.noteUnderCta}</p>
      </div>

      <div class="order-1 lg:order-2">
        <AppMockup content={content.mockup} />
      </div>
    </div>
  </Container>
</Section>
