---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { TrackRecordContent } from "@/content/pages/track-record/types";

interface Props {
  locale: Locale;
  content: TrackRecordContent["methodologyLink"];
}
const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<Section surface="light" spacing="lg" ariaLabelledby="track-methodology-h2">
  <Container size="md" class="text-center">
    <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pitch-green-500/15 text-pitch-green-600" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="2" width="16" height="20" rx="2"/>
        <line x1="8" y1="6" x2="16" y2="6"/>
        <line x1="8" y1="10" x2="16" y2="10"/>
        <line x1="8" y1="14" x2="13" y2="14"/>
      </svg>
    </span>
    <h2 id="track-methodology-h2" class="mt-5 text-3xl sm:text-4xl font-bold leading-tight tracking-tight text-charcoal-900">
      {content.h2}
    </h2>
    <p class="mt-5 text-lg leading-relaxed text-charcoal-700 max-w-2xl mx-auto">{content.body}</p>
    <a href={ctaHref} class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-600 hover:text-pitch-green-500 transition-colors">
      {content.cta.label}
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </a>
  </Container>
</Section>
