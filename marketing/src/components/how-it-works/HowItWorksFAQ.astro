---
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import type { HowItWorksContent } from "@/content/pages/how-it-works/types";

interface Props {
  content: HowItWorksContent["faq"];
}
const { content } = Astro.props;
---

<Section surface="light" spacing="lg" ariaLabelledby="faq">
  <Container size="md">
    <h2
      id="faq"
      class="scroll-mt-24 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-charcoal-900 text-center"
    >
      {content.h2}
    </h2>

    <div class="mt-10 divide-y divide-stadium-white-200 rounded-2xl border border-stadium-white-200 bg-white shadow-[var(--shadow-sm)]">
      {content.questions.map((item) => (
        <details class="group" name="hiw-faq">
          <summary class="flex items-center justify-between gap-4 cursor-pointer px-6 py-5 list-none text-left focus-visible:outline-none focus-visible:bg-stadium-white-100 rounded-2xl">
            <span class="text-base lg:text-lg font-semibold text-charcoal-900">{item.q}</span>
            <svg class="h-5 w-5 shrink-0 text-charcoal-500 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-base leading-relaxed text-charcoal-700">{item.a}</div>
        </details>
      ))}
    </div>
  </Container>
</Section>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ""; }
</style>
