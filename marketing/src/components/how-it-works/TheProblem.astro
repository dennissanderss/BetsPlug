---
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import { parseAccent } from "@/lib/parseAccent";
import type { HowItWorksContent } from "@/content/pages/how-it-works/types";

interface Props {
  content: HowItWorksContent["problem"];
}
const { content } = Astro.props;
---

<Section surface="light-soft" spacing="lg" ariaLabelledby="problem">
  <Container size="md">
    <h2
      id="problem"
      class="scroll-mt-24 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-charcoal-900"
      set:html={parseAccent(content.h2)}
    ></h2>
    <div class="mt-8 space-y-6 text-charcoal-700 text-lg leading-[1.65]">
      {content.paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </Container>
</Section>
