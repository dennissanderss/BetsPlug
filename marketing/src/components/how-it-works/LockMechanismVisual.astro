---
/**
 * Stage 4 visual — lock + timestamp display. Shows a generated
 * "Prediction generated → committed" mini-timeline with the lock
 * icon snapping shut. Animation is gated behind prefers-reduced-motion.
 *
 * Timestamp is hardcoded — never the current time, never tied to a
 * real fixture. Pure visual placeholder.
 */
import Icon from "@/components/ui/Icon.astro";

interface Props {
  labels: Record<string, string>;
}
const { labels } = Astro.props as Props;

const exampleTimestamp = "2026-05-04 14:23:45 UTC";
---

<div class="lock-visual w-full max-w-md mx-auto" aria-label={labels.aria ?? "Prediction lock mechanism"}>
  <div class="lock-visual__head">
    <span class="lock-visual__chip">
      <span class="lock-visual__dot"></span>
      LOCKED
    </span>
    <span class="lock-visual__timestamp">{exampleTimestamp}</span>
  </div>

  <div class="lock-visual__body">
    <div class="lock-visual__shackle" aria-hidden="true">
      <Icon name="lock" size={56} />
      <span class="lock-visual__pulse"></span>
    </div>
    <p class="lock-visual__status">{labels.status ?? "Prediction committed · Cannot be edited"}</p>
  </div>

  <div class="lock-visual__bar">
    <span class="lock-visual__bar-fill"></span>
  </div>
</div>

<style>
  .lock-visual {
    background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.875rem;
    padding: 1rem 1.25rem 1.25rem;
    text-align: center;
    color: var(--white-soft, #e8eaef);
  }
  .lock-visual__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .lock-visual__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    background: rgba(0, 210, 106, 0.14);
    border: 1px solid rgba(0, 210, 106, 0.3);
    color: var(--pitch-green-500, #00d26a);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .lock-visual__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pitch-green-500, #00d26a);
  }
  .lock-visual__timestamp {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
  }
  .lock-visual__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
  }
  .lock-visual__shackle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: rgba(0, 210, 106, 0.10);
    color: var(--pitch-green-500, #00d26a);
  }
  .lock-visual__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(0, 210, 106, 0.5);
    pointer-events: none;
  }
  .lock-visual__status {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--white-soft, #e8eaef);
    margin: 0;
    line-height: 1.4;
  }
  .lock-visual__bar {
    margin-top: 1rem;
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    overflow: hidden;
  }
  .lock-visual__bar-fill {
    display: block;
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #00B85A, #1FE07F);
    transform-origin: left;
  }

  @media (prefers-reduced-motion: no-preference) {
    .lock-visual__shackle :global(svg) {
      animation: lock-snap 1.6s ease-out 0.2s both;
      transform-origin: center;
    }
    .lock-visual__pulse {
      animation: lock-pulse 2.4s ease-out infinite;
    }
    .lock-visual__bar-fill {
      animation: lock-bar 1.4s ease-out both;
    }
  }
  @keyframes lock-snap {
    0%   { transform: scale(0.85); opacity: 0; }
    60%  { transform: scale(1.06); opacity: 1; }
    100% { transform: scale(1);    opacity: 1; }
  }
  @keyframes lock-pulse {
    0%   { transform: scale(1);    opacity: 0.7; }
    100% { transform: scale(1.35); opacity: 0;   }
  }
  @keyframes lock-bar {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
</style>
