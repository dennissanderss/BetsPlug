---
/**
 * HowItWorksPage — the body of /how-it-works for both the EN root
 * (src/pages/how-it-works.astro) and the locale variants
 * (src/pages/[locale]/[slug].astro).
 *
 * Visual design follows NOCTURNE:
 *   - Dark deep-navy surface with ambient pitch-green glow blobs
 *   - Each step card carries a hex-style icon badge + an oversized
 *     mono numeral, gradient-bordered card surface, and a
 *     dotted vertical connector that wires the six steps together
 *   - Trust pill below the steps points the visitor to /pricing
 *
 * The page is purely presentational — content comes from the
 * locale JSON loaded by the parent page.
 */
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import { parseAccent } from "@/lib/parseAccent";
import type { HowItWorksContent } from "@/content/pages/how-it-works/types";

interface Props {
  locale: Locale;
  content: HowItWorksContent;
}

const { locale, content } = Astro.props;

const ctaPrimaryHref = getLocalizedPath(content.ctaPrimary.canonical, locale);
const ctaSecondaryHref = getLocalizedPath(content.ctaSecondary.canonical, locale);
---

<section
  class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft pt-20 pb-12 sm:pt-24"
  aria-labelledby="hiw-h1"
>
  <!-- Ambient glow — top right -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-32 right-[-10%] h-[520px] w-[520px] rounded-full opacity-50 blur-[120px]"
    style="background: radial-gradient(circle, rgba(0,210,106,0.35) 0%, rgba(0,210,106,0) 70%);"
  ></div>

  <!-- Ambient glow — mid left -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-[40%] left-[-12%] h-[420px] w-[420px] rounded-full opacity-40 blur-[110px]"
    style="background: radial-gradient(circle, rgba(0,210,106,0.22) 0%, rgba(0,210,106,0) 70%);"
  ></div>

  <Container size="lg" class="relative">
    <!-- Header -->
    <header class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-pitch-green-400">
        {content.hero.kicker}
      </p>
      <h1
        id="hiw-h1"
        class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-white-pure"
        set:html={parseAccent(content.hero.title)}
      ></h1>
      <p class="mt-6 text-lg leading-relaxed text-white-soft">
        {content.hero.subtitle}
      </p>
    </header>
  </Container>
</section>

<section class="relative bg-deep-navy-900 pb-20 text-white-soft" aria-label="Six-step pipeline">
  <Container size="lg" class="relative">
    <ol class="relative mx-auto max-w-3xl">
      {/* Vertical connector line — full height of the steps stack */}
      <div
        aria-hidden="true"
        class="absolute left-[27px] top-8 bottom-8 hidden w-px sm:block"
        style="background: linear-gradient(to bottom, rgba(0,210,106,0.45), rgba(0,210,106,0.10) 70%, rgba(0,210,106,0));"
      ></div>

      {content.steps.map((step, i) => (
        <li class="relative pl-0 sm:pl-20" data-step-index={i}>
          <article class="relative mt-6 first:mt-0">
            {/* Numbered icon badge — sits on the connector line on desktop */}
            <div class="absolute left-0 top-0 hidden sm:block">
              <div
                class="relative flex h-14 w-14 items-center justify-center rounded-2xl
                       border border-pitch-green-500/40 bg-deep-navy-800
                       shadow-[0_0_24px_rgba(0,210,106,0.20)]"
              >
                <span class="text-pitch-green-400">
                  {step.icon === "database" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <ellipse cx="12" cy="5" rx="8" ry="3" />
                      <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5" />
                      <path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" />
                    </svg>
                  )}
                  {step.icon === "cpu" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="4" y="4" width="16" height="16" rx="2" />
                      <rect x="9" y="9" width="6" height="6" />
                      <line x1="9" y1="1" x2="9" y2="4" />
                      <line x1="15" y1="1" x2="15" y2="4" />
                      <line x1="9" y1="20" x2="9" y2="23" />
                      <line x1="15" y1="20" x2="15" y2="23" />
                      <line x1="20" y1="9" x2="23" y2="9" />
                      <line x1="20" y1="14" x2="23" y2="14" />
                      <line x1="1" y1="9" x2="4" y2="9" />
                      <line x1="1" y1="14" x2="4" y2="14" />
                    </svg>
                  )}
                  {step.icon === "layers" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polygon points="12 2 2 7 12 12 22 7 12 2" />
                      <polyline points="2 17 12 22 22 17" />
                      <polyline points="2 12 12 17 22 12" />
                    </svg>
                  )}
                  {step.icon === "lock" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="11" width="18" height="11" rx="2" />
                      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                  )}
                  {step.icon === "check" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                      <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                  )}
                  {step.icon === "eye" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                      <circle cx="12" cy="12" r="3" />
                    </svg>
                  )}
                </span>
              </div>
            </div>

            {/* Card surface */}
            <div
              class="relative rounded-2xl border border-deep-navy-600 bg-deep-navy-800/70 p-6
                     backdrop-blur-sm transition-all duration-200
                     hover:border-pitch-green-500/50 hover:shadow-[0_8px_32px_rgba(0,210,106,0.10)]"
            >
              {/* Mobile: inline icon row above title */}
              <div class="flex items-center gap-3 sm:hidden">
                <div
                  class="flex h-10 w-10 items-center justify-center rounded-xl
                         border border-pitch-green-500/40 bg-deep-navy-900 text-pitch-green-400"
                >
                  <span class="font-mono text-sm font-bold">{step.number}</span>
                </div>
                <h2 class="text-lg font-bold text-white-pure">{step.title}</h2>
              </div>

              {/* Desktop: number above title, icon is in the gutter */}
              <div class="hidden sm:block">
                <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-pitch-green-400">
                  Step {step.number}
                </p>
                <h2 class="mt-2 text-2xl font-bold leading-tight text-white-pure">
                  {step.title}
                </h2>
              </div>

              <p class="mt-3 text-sm leading-relaxed text-white-soft sm:mt-4 sm:text-base">
                {step.body}
              </p>
            </div>
          </article>
        </li>
      ))}
    </ol>

    <!-- CTA strip -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-3">
      <Button href={ctaPrimaryHref} variant="primary" size="lg" surface="dark">
        {content.ctaPrimary.label}
      </Button>
      <Button href={ctaSecondaryHref} variant="secondary" size="lg" surface="dark">
        {content.ctaSecondary.label}
      </Button>
    </div>
  </Container>
</section>
