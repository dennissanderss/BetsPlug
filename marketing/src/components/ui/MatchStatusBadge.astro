---
/**
 * MatchStatusBadge — football match-state badge (LIVE / FT / HT / AET
 * / PEN / POSTPONED / CANCELLED / TBD / UPCOMING). Sport-DNA primitive
 * that mirrors the labels broadcast scoreboards use, sized for the
 * top bar of PredictionCard or any compact match listing.
 *
 * Status colour conventions (broadcast-feel without literal red dot):
 *   - LIVE       → red (with optional pulse dot)
 *   - HT         → amber
 *   - FT/AET/PEN → neutral grey (match concluded)
 *   - UPCOMING   → pitch-green
 *   - POSTPONED/CANCELLED/TBD → muted grey
 *
 * Pulse animation is reserved for `live` and respects
 * prefers-reduced-motion. Hidden text via .sr-only on the dot keeps
 * screen readers from shouting the label twice.
 */
import { formatMatchStatus, type MatchStatus } from "@/lib/time";

type Size = "sm" | "md";

interface Props {
  status: MatchStatus;
  size?: Size;
  /** Whether the LIVE badge should pulse. Honoured only when
   *  status === "live". Defaults to true. */
  pulse?: boolean;
  /** Extra utility classes on the root. */
  class?: string;
}

const {
  status,
  size = "sm",
  pulse = true,
  class: extraClass = "",
} = Astro.props as Props;

const label = formatMatchStatus(status);
const showPulse = status === "live" && pulse;

const cls = [
  "match-status-badge",
  `match-status-badge--${size}`,
  `match-status-badge--${status}`,
  showPulse && "match-status-badge--pulse",
  extraClass,
].filter(Boolean).join(" ");
---

<span class={cls} role="status">
  {showPulse && <span class="status-dot" aria-hidden="true"></span>}
  <span class="status-label">{label}</span>
</span>

<style>
  .match-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.625rem; /* 10px */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid;
  }

  .match-status-badge--md {
    padding: 0.3rem 0.625rem;
    font-size: 0.6875rem; /* 11px */
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: currentColor;
  }

  /* ── Status colours ──────────────────────────────────────────── */

  .match-status-badge--live {
    color: #ff3b30;
    background: rgba(255, 59, 48, 0.10);
    border-color: rgba(255, 59, 48, 0.30);
  }

  .match-status-badge--ht {
    color: #f59e0b; /* warning */
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.30);
  }

  .match-status-badge--ft,
  .match-status-badge--aet,
  .match-status-badge--pen {
    color: #9ba3b5; /* charcoal-300 / white-muted */
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .match-status-badge--upcoming {
    color: #00d26a; /* pitch-green-500 */
    background: rgba(0, 210, 106, 0.08);
    border-color: rgba(0, 210, 106, 0.25);
  }

  .match-status-badge--postponed,
  .match-status-badge--cancelled,
  .match-status-badge--tbd {
    color: #5a6478; /* charcoal-500 / white-faded */
    background: rgba(91, 100, 120, 0.10);
    border-color: rgba(91, 100, 120, 0.25);
  }

  /* ── Pulse animation (LIVE only) ─────────────────────────────── */

  .match-status-badge--pulse .status-dot {
    animation: status-pulse 1.6s ease-in-out infinite;
    transform-origin: center;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .match-status-badge--pulse .status-dot { animation: none; }
  }
</style>
