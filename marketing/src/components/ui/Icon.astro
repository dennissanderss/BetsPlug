---
/**
 * Icon — inline SVG wrapper that draws Lucide-style icons without
 * adding an npm dependency. Each icon is a hand-curated path lifted
 * from Lucide so we keep tree-shaking automatic (only icons used
 * across the codebase end up in HTML output).
 *
 * Style matches Lucide defaults: 24×24 viewBox, stroke-width 2,
 * round caps + joins, `none` fill — colour from `currentColor`.
 *
 * Add a new icon by appending its name + `<path>` block to the
 * ICONS map. Source paths can be copied verbatim from
 * https://lucide.dev/icons/<name>.
 */

import type { IconName } from "@/components/ui/icon-types";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 18, class: extraClass = "", ariaLabel } = Astro.props as Props;

// Lucide icon body (everything between <svg>…</svg> minus the
// outer element). Keep these short — they're inlined per render so
// the only cost is ~1 SVG per icon in HTML.
