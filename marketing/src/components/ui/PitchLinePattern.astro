---
/**
 * PitchLinePattern — sport-DNA SVG overlay inspired by football pitch
 * markings (centre circle, penalty box, goal box, halfway line). Used
 * as an absolutely-positioned background pattern inside any container
 * that has `position: relative`.
 *
 * Tone strategy (see docs/specs/04-design-system.md → SPORT-DNA):
 *   - subtle: landing/conversion pages — almost imperceptible, hints
 *     at the sport without distracting from copy.
 *   - medium: educational pages (methodology, how-it-works) — visible
 *     enough to anchor the sport context.
 *   - bold:   predictions/track-record/league pages — engaged users
 *     get a stronger sport identity.
 *
 * Position lets you fade the pattern to one half of the section so
 * heads/copy stay readable: "top", "bottom", "right" apply a linear
 * mask; "full" tiles edge-to-edge.
 *
 * Designed for dark surfaces. White lines compose well against the
 * deep-navy palette; on light surfaces the pattern is almost invisible
 * by design (we don't currently render it on light sections).
 */
type Variant  = "subtle" | "medium" | "bold";
type Position = "full" | "top" | "bottom" | "right";

interface Props {
  variant?: Variant;
  position?: Position;
  /** Extra utility classes on the root SVG. */
  class?: string;
}

const {
  variant = "subtle",
  position = "full",
  class: extraClass = "",
} = Astro.props as Props;

// Opacity ramp — keeps the pattern present-but-restrained on landing
// surfaces (~5%) and steps up for sport surfaces. Numbers picked to
// stay visible on dark navy without ever turning the section into a
// decorative pitch graphic.
const opacityMap: Record<Variant, number> = {
  subtle: 0.05,
  medium: 0.08,
  bold:   0.12,
};
const opacity = opacityMap[variant];

// Pattern size — 320×320 keeps the pitch markings legible without
// becoming a wallpaper at large viewports.
const TILE = 320;

// Unique pattern id per variant so multiple instances on the same
// page (e.g. nested sections) don't collide.
const patternId = `pitch-lines-${variant}`;
---

<svg
  aria-hidden="true"
  class:list={[
    "pitch-pattern",
    `pitch-pattern--${position}`,
    extraClass,
  ]}
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="xMidYMid slice"
  data-variant={variant}
>
  <defs>
    <pattern
      id={patternId}
      x="0"
      y="0"
      width={TILE}
      height={TILE}
      patternUnits="userSpaceOnUse"
    >
      {/* Halfway line */}
      <line
        x1="0" y1={TILE / 2} x2={TILE} y2={TILE / 2}
        stroke="white" stroke-width="1.25"
        opacity={opacity}
      />
      {/* Centre circle */}
      <circle
        cx={TILE / 2} cy={TILE / 2} r="58"
        fill="none"
        stroke="white" stroke-width="1.25"
        opacity={opacity}
      />
      {/* Centre spot */}
      <circle
        cx={TILE / 2} cy={TILE / 2} r="2"
        fill="white"
        opacity={opacity * 1.4}
      />
      {/* Penalty box (left half) */}
      <rect
        x="0" y={TILE / 2 - 78} width="100" height="156"
        fill="none"
        stroke="white" stroke-width="1.25"
        opacity={opacity}
      />
      {/* Goal box (left, smaller) */}
      <rect
        x="0" y={TILE / 2 - 36} width="44" height="72"
        fill="none"
        stroke="white" stroke-width="1.25"
        opacity={opacity}
      />
      {/* Penalty spot (left) */}
      <circle
        cx="64" cy={TILE / 2} r="2"
        fill="white"
        opacity={opacity * 1.4}
      />
      {/* Penalty arc (left) — partial circle outside the box */}
      <path
        d={`M 100 ${TILE / 2 - 24} A 28 28 0 0 1 100 ${TILE / 2 + 24}`}
        fill="none"
        stroke="white" stroke-width="1.25"
        opacity={opacity}
      />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${patternId})`} />
</svg>

<style>
  .pitch-pattern {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* Position variants fade the pattern to one half of the section so
     it never competes with copy. Mask is fully transparent at the
     fade edge, fully opaque where we want the pattern present. */
  .pitch-pattern--top {
    bottom: auto;
    height: 60%;
    -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
            mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
  }

  .pitch-pattern--bottom {
    top: auto;
    height: 60%;
    -webkit-mask-image: linear-gradient(to top, black 30%, transparent 100%);
            mask-image: linear-gradient(to top, black 30%, transparent 100%);
  }

  .pitch-pattern--right {
    left: auto;
    width: 60%;
    -webkit-mask-image: linear-gradient(to left, black 30%, transparent 100%);
            mask-image: linear-gradient(to left, black 30%, transparent 100%);
  }

  .pitch-pattern--full {
    /* Soft vignette so the centre is the strongest area and edges
       fade out — keeps section corners visually clean. */
    -webkit-mask-image: radial-gradient(ellipse at centre, black 40%, transparent 90%);
            mask-image: radial-gradient(ellipse at centre, black 40%, transparent 90%);
  }
</style>
