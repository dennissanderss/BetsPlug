---
/**
 * ScoreNumber — TV-scoreboard style numeric display.
 * Sport-DNA primitive for stat callouts: monospace, tabular-nums, a
 * subtle scoreboard "bezel" (gradient + inner highlight) that hints
 * at a stadium scoreboard without being literal.
 *
 * Use for stats that benefit from being read as numbers, not headings:
 * homepage section stats ("30+ leagues"), pricing tier prices,
 * matchweek labels, prediction confidences, model variable counts.
 *
 * Variants:
 *   - default:   neutral (white on dark / charcoal on light)
 *   - highlight: pitch-green tinted bezel — the "headline" stat in a
 *                section. Don't stack two side by side; pick one.
 *   - win:       pitch-green text only (use inside a list of W/L stats)
 *   - loss:      danger-red text only
 *
 * Surface is auto-detected from the closest [data-surface="light"]
 * ancestor. Pass `surface="light"` explicitly when the auto-detect
 * doesn't fit (e.g. a card on a dark surface that mimics a light card).
 */
type Size    = "sm" | "md" | "lg" | "xl";
type Variant = "default" | "highlight" | "win" | "loss";
type Surface = "auto" | "dark" | "light";

interface Props {
  value: string | number;
  /** Optional caption underneath the number. */
  label?: string;
  size?: Size;
  variant?: Variant;
  /** Currency or symbol prefix, e.g. "€". Smaller weight than value. */
  prefix?: string;
  /** Unit suffix, e.g. "+", "%", "/day". Smaller weight than value. */
  suffix?: string;
  surface?: Surface;
  /** Extra utility classes on the root. */
  class?: string;
}

const {
  value,
  label,
  size = "md",
  variant = "default",
  prefix,
  suffix,
  surface = "auto",
  class: extraClass = "",
} = Astro.props as Props;

const cls = [
  "score-number",
  `score-number--${size}`,
  `score-number--${variant}`,
  surface !== "auto" && `score-number--surface-${surface}`,
  extraClass,
].filter(Boolean).join(" ");
---

<div class={cls}>
  <div class="score-display">
    {prefix && <span class="score-prefix">{prefix}</span>}
    <span class="score-value">{value}</span>
    {suffix && <span class="score-suffix">{suffix}</span>}
  </div>
  {label && <div class="score-label">{label}</div>}
</div>

<style>
  .score-number {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .score-display {
    display: inline-flex;
    align-items: baseline;
    gap: 0.125rem;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    /* Default: dark-surface bezel (white text on a soft dark scoreboard) */
    color: var(--color-white-pure);
    background:
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.01)
      );
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.25);
    padding: 0.5rem 0.875rem;
    /* Tabular numerals so digits don't shift width when the value
       changes (relevant for animated counters). */
  }

  .score-value { font-variant-numeric: tabular-nums; }

  .score-prefix,
  .score-suffix {
    font-size: 0.62em;
    font-weight: 600;
    color: var(--color-white-muted);
  }

  .score-label {
    font-size: 0.6875rem; /* 11px */
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-white-muted);
    text-align: center;
  }

  /* ── Sizes ───────────────────────────────────────────────────── */

  .score-number--sm .score-display {
    font-size: 1rem;            /* 16px */
    padding: 0.3rem 0.55rem;
  }
  .score-number--md .score-display {
    font-size: 1.5rem;          /* 24px */
    padding: 0.5rem 0.875rem;
  }
  .score-number--lg .score-display {
    font-size: 2.25rem;         /* 36px */
    padding: 0.6rem 1.1rem;
  }
  .score-number--xl .score-display {
    font-size: 3rem;            /* 48px */
    padding: 0.8rem 1.4rem;
    font-weight: 800;
  }

  /* Mobile: scale xl/lg down so they don't wrap on 375px viewports. */
  @media (max-width: 480px) {
    .score-number--xl .score-display { font-size: 2.25rem; padding: 0.65rem 1rem; }
    .score-number--lg .score-display { font-size: 1.85rem; padding: 0.55rem 0.95rem; }
  }

  /* ── Variants ────────────────────────────────────────────────── */

  .score-number--highlight .score-display {
    color: var(--color-pitch-green-400);
    background:
      linear-gradient(
        to bottom,
        rgba(0, 210, 106, 0.10),
        rgba(0, 210, 106, 0.04)
      );
    border-color: rgba(0, 210, 106, 0.25);
    box-shadow:
      inset 0 1px 0 rgba(0, 210, 106, 0.12),
      0 0 0 1px rgba(0, 210, 106, 0.06),
      0 4px 16px rgba(0, 210, 106, 0.10);
  }
  .score-number--highlight .score-prefix,
  .score-number--highlight .score-suffix {
    color: var(--color-pitch-green-400);
    opacity: 0.85;
  }

  .score-number--win  .score-display { color: var(--color-pitch-green-400); }
  .score-number--loss .score-display { color: var(--color-danger); }

  /* ── Light-surface inversion ─────────────────────────────────── */

  /* Auto: when an ancestor declares data-surface="light" (added on
     light Section/Card surfaces) the bezel inverts. */
  :global([data-surface="light"]) .score-number .score-display,
  .score-number--surface-light .score-display {
    color: var(--color-charcoal-900);
    background:
      linear-gradient(
        to bottom,
        rgba(15, 20, 25, 0.04),
        rgba(15, 20, 25, 0.01)
      );
    border-color: rgba(15, 20, 25, 0.10);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 1px 2px rgba(15, 20, 25, 0.05);
  }

  :global([data-surface="light"]) .score-number .score-prefix,
  :global([data-surface="light"]) .score-number .score-suffix,
  .score-number--surface-light .score-prefix,
  .score-number--surface-light .score-suffix {
    color: var(--color-charcoal-500);
  }

  :global([data-surface="light"]) .score-number .score-label,
  .score-number--surface-light .score-label {
    color: var(--color-charcoal-500);
  }

  :global([data-surface="light"]) .score-number--highlight .score-display,
  .score-number--surface-light.score-number--highlight .score-display {
    color: var(--color-pitch-green-600);
    background:
      linear-gradient(
        to bottom,
        rgba(0, 210, 106, 0.08),
        rgba(0, 210, 106, 0.02)
      );
    border-color: rgba(0, 210, 106, 0.25);
  }
</style>
