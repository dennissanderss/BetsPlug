---
import Container from "@/components/ui/Container.astro";
import type { FAQContent } from "@/content/pages/faq/types";

interface Props { content: FAQContent["hero"] }
const { content } = Astro.props;
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[25vh] py-12 md:py-16" aria-labelledby="faq-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-dark);"></div>

  <Container size="md" class="relative text-center">
    <h1 id="faq-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] tracking-tight text-white-pure">
      {content.h1}
    </h1>
    <p class="mt-4 text-base sm:text-lg leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>
  </Container>
</section>
