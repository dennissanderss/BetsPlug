---
/**
 * BetTypeSection — single bet-type deep-dive (used 8x).
 * Two-column desktop: 60% text content + 40% example prediction card.
 */
import type { BetTypeSection, BetTypesContent } from "@/content/pages/bet-types/types";

interface Props {
  section: BetTypeSection;
  labels: BetTypesContent["sectionLabels"];
}
const { section, labels } = Astro.props;
---

<section id={section.id} class="scroll-mt-24 mt-16 first:mt-0">
  <h2 class="text-2xl sm:text-3xl font-bold leading-tight tracking-tight text-charcoal-900">
    {section.h2}
  </h2>
  <p class="mt-2 text-base lg:text-lg italic text-charcoal-700">{section.definition}</p>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- Body 60% -->
    <div class="lg:col-span-7 space-y-6">
      <div>
        <h3 class="text-base font-bold text-charcoal-900">{labels.howItWorks}</h3>
        <div class="mt-2 space-y-3 text-sm leading-relaxed text-charcoal-700">
          {section.howItWorks.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <div>
        <h3 class="text-base font-bold text-charcoal-900">{labels.whenPredictable}</h3>
        <div class="mt-2 space-y-3 text-sm leading-relaxed text-charcoal-700">
          {section.whenPredictable.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <div>
        <h3 class="text-base font-bold text-charcoal-900">{labels.howBetsplugPredicts}</h3>
        <div class="mt-2 space-y-3 text-sm leading-relaxed text-charcoal-700">
          {section.howBetsplugPredicts.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <div>
        <h3 class="text-base font-bold text-charcoal-900">{labels.tips}</h3>
        <ul class="mt-2 space-y-2 text-sm leading-relaxed text-charcoal-700 list-disc pl-5">
          {section.tips.map((tip) => <li>{tip}</li>)}
        </ul>
      </div>
    </div>

    <!-- Example card 40% -->
    <div class="lg:col-span-5">
      <div class="lg:sticky lg:top-24">
        <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500 mb-3">
          {labels.exampleTitle}
        </p>
        <div class="rounded-xl border border-deep-navy-600 bg-charcoal-700 p-5 text-white-soft">
          <div class="flex items-center justify-between text-xs">
            <span class="inline-flex items-center gap-1.5 font-semibold">
              <span class="h-1.5 w-1.5 rounded-full bg-pitch-green-500" aria-hidden="true"></span>
              {section.example.league}
            </span>
            <span class="inline-flex items-center rounded-full bg-pitch-green-500/15 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-pitch-green-400">
              Example
            </span>
          </div>
          <div class="mt-4 space-y-2">
            <p class="text-sm font-semibold text-white-pure truncate">{section.example.homeTeam}</p>
            <p class="text-sm font-semibold text-white-pure truncate">{section.example.awayTeam}</p>
          </div>
          <p class="mt-5 text-base font-bold text-pitch-green-400">{section.example.prediction}</p>
          <div class="mt-3">
            <div class="flex items-center justify-between text-xs">
              <span class="text-white-muted">Confidence</span>
              <span class="font-mono font-semibold text-white-pure">{section.example.confidence}%</span>
            </div>
            <div class="mt-1.5 h-1.5 rounded-full bg-deep-navy-900 overflow-hidden">
              <div class="h-full rounded-full bg-pitch-green-500" style={`width: ${section.example.confidence}%;`}></div>
            </div>
          </div>
          <p class="mt-4 text-[11px] text-white-muted">🔒 Locked before kickoff</p>
        </div>
      </div>
    </div>
  </div>
</section>
