---
import Container from "@/components/ui/Container.astro";
import GlowOrb from "@/components/ui/GlowOrb.astro";
import StadiumLightArc from "@/components/ui/StadiumLightArc.astro";
import AccentGrid from "@/components/ui/AccentGrid.astro";
import { parseAccent } from "@/lib/parseAccent";
import type { BetTypesContent } from "@/content/pages/bet-types/types";

interface Props { content: BetTypesContent["hero"] }
const { content } = Astro.props;
---

<section class="relative w-full overflow-hidden bg-deep-navy-900 text-white-soft min-h-[35vh] py-14 md:py-20 isolate" aria-labelledby="bet-types-hero-h1">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: var(--gradient-hero-atmospheric);"></div>
  <StadiumLightArc position="top-center" intensity="low" />
  <GlowOrb size="xl" color="pitch-green" position="top-right" intensity="medium" blur={120} />
  <AccentGrid variant="subtle" position="top-right" fade />

  <Container size="md" class="relative z-10 text-center">
    <h1 id="bet-types-hero-h1" class="text-3xl sm:text-4xl lg:text-5xl xl:text-[56px] font-bold leading-[1.05] tracking-tight text-white-pure" set:html={parseAccent(content.h1)}></h1>
    <p class="mt-6 text-lg sm:text-xl leading-relaxed text-white-soft max-w-2xl mx-auto">{content.subheadline}</p>
  </Container>
</section>
