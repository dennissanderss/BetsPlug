---
import { getLocalizedPath, type Locale } from "@/lib/i18n";
import type { BetTypesContent } from "@/content/pages/bet-types/types";

interface Props {
  locale: Locale;
  content: BetTypesContent["coverage"];
}
const { locale, content } = Astro.props;
const ctaHref = getLocalizedPath(content.cta.canonical, locale);
---

<section id="coverage" class="scroll-mt-24 mt-16">
  <h2 class="text-2xl sm:text-3xl font-bold leading-tight tracking-tight text-charcoal-900">{content.h2}</h2>
  <p class="mt-3 text-base text-charcoal-700">{content.body}</p>

  <div class="mt-8 overflow-hidden rounded-2xl border border-stadium-white-200 bg-white shadow-[var(--shadow-sm)]">
    <table class="w-full text-left">
      <thead class="bg-stadium-white-100">
        <tr>
          <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-charcoal-500">{content.headers.betType}</th>
          <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-charcoal-500 text-center">{content.headers.freeTier}</th>
          <th scope="col" class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-pitch-green-600 text-center">{content.headers.paidTier}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stadium-white-200">
        {content.rows.map((row) => (
          <tr>
            <th scope="row" class="px-6 py-3 text-sm font-medium text-charcoal-900">{row.betType}</th>
            <td class="px-6 py-3 text-center">
              {row.free ? (
                <svg class="inline h-5 w-5 text-pitch-green-600" viewBox="0 0 20 20" fill="currentColor" aria-label="Included">
                  <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              ) : (
                <span class="text-charcoal-400" aria-label="Not included">—</span>
              )}
            </td>
            <td class="px-6 py-3 text-center text-sm font-medium text-charcoal-900">
              {row.paid === true ? (
                <svg class="inline h-5 w-5 text-pitch-green-600" viewBox="0 0 20 20" fill="currentColor" aria-label="Included">
                  <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              ) : row.paid === false ? (
                <span class="text-charcoal-400">—</span>
              ) : (
                <span class="inline-flex items-center gap-1">
                  <svg class="h-5 w-5 text-pitch-green-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.704 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.29-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs">({row.paid})</span>
                </span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="mt-4 text-sm italic text-charcoal-500">{content.note}</p>

  <div class="mt-6 text-center">
    <a href={ctaHref} class="inline-flex items-center gap-2 text-sm font-semibold text-pitch-green-600 hover:text-pitch-green-500 transition-colors">
      {content.cta.label}
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>
